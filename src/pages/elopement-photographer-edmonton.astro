---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const faqs = [
  { q: 'How much does an elopement photographer cost in Edmonton?', a: 'Elopement photography starts at $2,250. Photo + video elopement packages are also available. Every elopement is different — reach out with your plans and I\'ll put together a custom quote.' },
  { q: 'What is included in an elopement photography package?', a: 'Every package includes professional editing, an online gallery with full download rights, colour grading, and timeline planning assistance. Depending on the package, you may also receive a second shooter, engagement session, or cinematic highlight film.' },
  { q: 'Do you offer elopement videography too?', a: 'Yes — I offer combined photo + video elopement packages. Having one team for both means your photos and film match in mood and style. Perfect for couples who want the full story documented without the full wedding crew.' },
  { q: 'Where are the best elopement locations near Edmonton?', a: 'Popular spots include the river valley parks, Elk Island National Park, the Legislature Grounds, and Hawrelak Park. For mountain elopements, Banff, Jasper, Lake Louise, and Kananaskis are 3-4 hours from Edmonton and absolutely stunning.' },
  { q: 'Do you travel to Banff or Jasper for elopements?', a: 'Absolutely. Mountain elopements are some of my favourite work. I regularly travel to Banff, Jasper, Lake Louise, Canmore, and Kananaskis. Travel is included or quoted based on distance — just tell me where your dream location is.' },
  { q: 'How many photos will I receive from my elopement?', a: 'A typical 2-4 hour elopement receives 150-300+ professionally edited images. Longer elopements with multiple locations or a reception dinner may receive 400+.' },
  { q: 'Can we elope with just the two of us?', a: 'Of course — many of my couples elope with just the two of them and me behind the camera. No guests required. Some couples invite a handful of close family or friends, and that works beautifully too.' },
  { q: 'What should we wear for our elopement?', a: "Wear whatever feels like you. Some couples go full formal — wedding dress and suit in the mountains. Others keep it casual with jeans and a vintage jacket. The best elopement outfits are the ones you feel most comfortable and confident in." },
  { q: 'Do you help with elopement planning?', a: "I can help with timeline planning, location scouting, and permit requirements for national parks. I have shot at most major outdoor locations near Edmonton and in the Rockies, so I know what works best at different times of day and seasons." },
];

const locations = [
  { name: 'River Valley', desc: 'Edmonton\'s 48km river valley — the largest urban park in Canada. Wildflowers, bridges, golden light.', type: 'Urban' },
  { name: 'Banff & Lake Louise', desc: '3.5 hours from Edmonton. Turquoise lakes, dramatic peaks, iconic mountain ceremony spots.', type: 'Mountain' },
  { name: 'Jasper National Park', desc: '3.5 hours west. Less crowded than Banff, equally stunning. Maligne Lake, Athabasca Falls, Pyramid Lake.', type: 'Mountain' },
  { name: 'Kananaskis', desc: 'The quiet alternative to Banff — fewer crowds, same mountain grandeur. Perfect for intimate ceremonies.', type: 'Mountain' },
];

const galleryImages = [
  { src: '/gallery-images/engagement/021-banff-lake-minnewanka-couple-portrait.jpg', alt: 'Banff elopement photography — Lake Minnewanka couple portrait by MH Photography Edmonton' },
  { src: '/gallery-images/engagement/022-lake-minnewanka-engagement-session.jpg', alt: 'Lake Minnewanka elopement — intimate mountain ceremony photographer' },
  { src: '/gallery-images/engagement/019-engagement-session-cherry-blossom-edmonton.jpg', alt: 'Cherry blossom elopement Edmonton — intimate wedding photographer' },
  { src: '/gallery-images/engagement/023-banff-engagement-mountain-backdrop.jpg', alt: 'Banff mountain elopement — adventure wedding photographer Edmonton' },
  { src: '/gallery-images/engagement/024-lake-minnewanka-romantic-moment.jpg', alt: 'Intimate mountain moment — elopement photography Banff' },
  { src: '/gallery-images/weddings/002-first-look.jpg', alt: 'First look moment — intimate wedding photographer Edmonton' },
  { src: '/gallery-images/engagement/020-engagement-couple-cherry-blossom-closeup-edmonton.jpg', alt: 'Cherry blossom couple closeup — Edmonton elopement photographer' },
  { src: '/gallery-images/weddings/010-aisle-walk.jpg', alt: 'Walking together — intimate ceremony photography Edmonton' },
  { src: '/gallery-images/engagement/001-Miranda.jpg', alt: 'Engagement session Edmonton — elopement and intimate wedding photography' },
  { src: '/gallery-images/family/002-fall-family-candid.jpg', alt: 'Golden hour candid — outdoor photographer Edmonton' },
  { src: '/gallery-images/engagement/003-Picture-7-2.jpg', alt: 'Couple portrait session — Edmonton elopement photographer' },
  { src: '/gallery-images/weddings/009-ceremony-moment.jpg', alt: 'Ceremony emotion — documentary elopement photographer Edmonton' },
];
---

<BaseLayout
  title="Elopement Photographer Edmonton | Intimate Weddings & Mountain Elopements"
  description="Edmonton elopement photographer. Intimate ceremonies, mountain elopements in Banff & Jasper, river valley weddings. Photo + video from $2,250. Book 2026 & 2027."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Elopement Photography Edmonton",
      "description": "Intimate elopement and micro-wedding photography in Edmonton, Banff, Jasper, and across Alberta. Packages from $2,250. Photo + video elopement packages available.",
      "url": "https://mhphoto.ca/elopement-photographer-edmonton/",
      "serviceType": "Elopement Photography",
      "provider": {
        "@type": "PhotographyBusiness",
        "name": "MH Photography",
        "url": "https://mhphoto.ca",
        "email": "moein@mhphoto.ca",
        "founder": { "@type": "Person", "name": "Moein Habibi" },
        "address": { "@type": "PostalAddress", "addressLocality": "Edmonton", "addressRegion": "AB", "addressCountry": "CA" }
      },
      "areaServed": [
        { "@type": "City", "name": "Edmonton" },
        { "@type": "City", "name": "Sherwood Park" },
        { "@type": "City", "name": "St. Albert" },
        { "@type": "Place", "name": "Banff National Park" },
        { "@type": "Place", "name": "Jasper National Park" },
        { "@type": "AdministrativeArea", "name": "Alberta" }
      ],
      "offers": {
        "@type": "Offer",
        "priceCurrency": "CAD",
        "price": "2250",
        "description": "Elopement photography starting price",
        "url": "https://mhphoto.ca/elopement-photographer-edmonton/"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mhphoto.ca/" },
        { "@type": "ListItem", "position": 2, "name": "Photography", "item": "https://mhphoto.ca/photography/" },
        { "@type": "ListItem", "position": 3, "name": "Elopement Photography", "item": "https://mhphoto.ca/elopement-photographer-edmonton/" }
      ]
    })} />
  </Fragment>

  <!-- Breadcrumb -->
  <p class="text-sm font-light mb-1">
    <a href="/photography/" class="text-ink-muted hover:text-gold transition-colors">Photography</a>
    <span class="mx-1.5 text-ink-muted/40">/</span>
    <strong class="font-medium text-ink">Elopements</strong>
  </p>

  <!-- ============================================= -->
  <!-- HERO -->
  <!-- ============================================= -->
  <section class="mb-16 md:mb-20 reveal">
    <div class="max-w-2xl">
      <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">{site.booking}</p>
      <h1 class="font-serif font-light text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.08] tracking-[-0.02em] text-ink mb-5">
        Elopement Photographer in Edmonton
      </h1>
      <p class="font-light text-ink-soft text-[0.95rem] leading-[1.75]">
        Skip the guest list. Keep the love. Whether it's a mountaintop in Banff, a quiet clearing in the river valley, or your favourite spot in the city — I'll be there to document it. Just the two of you, your story, and photos that feel exactly like how the day felt.
      </p>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- HERO IMAGE GRID — aspirational landscape -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <div class="col-span-2 md:col-span-2 md:row-span-2 rounded-2xl overflow-hidden">
        <img
          src="/gallery-images/engagement/021-banff-lake-minnewanka-couple-portrait.jpg"
          alt="Banff elopement photography — couple portrait at Lake Minnewanka by Edmonton elopement photographer"
          class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700"
          loading="eager"
        />
      </div>
      <div class="rounded-2xl overflow-hidden">
        <img
          src="/gallery-images/engagement/019-engagement-session-cherry-blossom-edmonton.jpg"
          alt="Cherry blossom elopement — Edmonton intimate wedding photographer"
          class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700"
          loading="eager"
        />
      </div>
      <div class="rounded-2xl overflow-hidden">
        <img
          src="/gallery-images/engagement/023-banff-engagement-mountain-backdrop.jpg"
          alt="Mountain elopement Banff — adventure wedding photography"
          class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- WHY ELOPE — emotional pitch -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="max-w-2xl mx-auto">
      <div class="w-8 h-px bg-gold/40 mb-8"></div>
      <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-6">
        Your wedding, your way.
      </h2>
      <div class="space-y-4 font-light text-ink-soft text-[0.9rem] leading-[1.8]">
        <p>
          Not every love story needs 200 guests to witness it. Some of the most powerful weddings I've photographed
          have been two people, a quiet place, and a promise. That's it.
        </p>
        <div class="bg-gold/[0.06] border-l-2 border-gold/30 rounded-r-xl px-5 py-4">
          <p>
            Elopements aren't about cutting corners — they're about cutting the noise.
            No seating charts, no vendor coordination chaos, no performing for a crowd.
            Just you two, fully present, in a place that means something to you.
            And photographs that prove it actually happened.
          </p>
        </div>
        <p>
          I approach elopements the same way I approach full weddings — documentary style, real moments, no stiff poses.
          Whether you're standing on a ridgeline in <strong class="font-medium text-ink">Jasper</strong>, exchanging vows in
          <strong class="font-medium text-ink">Edmonton's river valley</strong>, or eloping at
          <strong class="font-medium text-ink">Lake Louise</strong> with nobody but the mountains watching —
          I'll capture the way it actually felt. Not a curated version. The real thing.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- PRICING PREVIEW -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">Elopement Packages</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-8">
      Pricing
    </h2>
    <div class="max-w-lg mx-auto">
      <div class="rounded-2xl ring-1 ring-ink/[0.08] overflow-hidden bg-white shadow-sm">
        <div class="relative h-[220px] overflow-hidden">
          <img src="/gallery-images/engagement/021-banff-lake-minnewanka-couple-portrait.jpg" alt="Elopement photography Edmonton — intimate wedding packages" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
        <div class="p-6">
          <h3 class="font-serif font-light text-lg text-gold-warm text-center tracking-wide uppercase mb-0.5">Elopement Photography</h3>
          <p class="text-[0.75rem] text-ink-muted text-center font-light mb-4">Intimate & Micro-Wedding Packages</p>
          <p class="text-[0.8rem] font-light text-ink-soft text-center leading-relaxed mb-5 px-2">
            Every elopement is unique — whether it's just the two of you or a small gathering, I'll put together a package that fits your day perfectly.
          </p>
          <div class="bg-[#f7f5f2] rounded-xl px-4 py-3 mb-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-gold-warm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="7" width="20" height="14" rx="2" />
                  <path d="M16 3v4M8 3v4" />
                  <circle cx="12" cy="15" r="2" />
                </svg>
              </div>
              <div>
                <p class="text-[0.7rem] text-ink-muted font-light leading-tight">Elopement photography starts at</p>
                <p class="text-lg font-serif font-light text-ink">$2,250</p>
              </div>
            </div>
          </div>
          <a href="/contact/" class="block text-center font-semibold text-[0.7rem] tracking-[0.14em] uppercase bg-ink text-white py-3 rounded-full hover:bg-[#333] transition-colors duration-300 mb-3">
            Let's Talk
          </a>
          <p class="text-[0.7rem] font-light text-ink-muted text-center">
            Photo + video elopement packages also available. <a href="/contact/" class="text-gold hover:text-gold-deep transition-colors">Reach out</a> and tell me about your plans.
          </p>
        </div>
      </div>
    </div>
    <p class="text-center mt-6">
      <a href="/pricing/" class="font-light text-sm text-ink border-b border-ink/30 pb-0.5 hover:border-ink transition-colors duration-300">
        View all packages &rarr;
      </a>
    </p>
  </section>

  <!-- ============================================= -->
  <!-- LOCATIONS -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">Where to Elope</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-8">
      Best elopement locations near Edmonton
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {locations.map((loc) => (
        <div class="bg-cream-warm rounded-xl p-6 border border-ink/[0.04]">
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-serif font-normal text-base text-ink">{loc.name}</h3>
            <span class="text-[0.55rem] font-medium tracking-[0.12em] uppercase text-gold bg-gold/10 px-2 py-0.5 rounded-full">{loc.type}</span>
          </div>
          <p class="font-light text-ink-soft text-[0.8rem] leading-relaxed">{loc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================= -->
  <!-- GALLERY -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">Portfolio</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-6">
      Intimate moments, real stories
    </h2>
    <div class="columns-2 md:columns-3 gap-3 space-y-3">
      {galleryImages.map((img) => (
        <div class="break-inside-avoid rounded-lg overflow-hidden">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-auto object-cover hover:scale-[1.02] transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
    <div class="flex items-center justify-center gap-6 mt-8">
      <a href="/photography/weddings/" class="font-light text-sm text-ink border-b border-ink/30 pb-0.5 hover:border-ink transition-colors duration-300">
        Wedding gallery &rarr;
      </a>
      <a href="/photography/engagement/" class="font-light text-sm text-ink border-b border-ink/30 pb-0.5 hover:border-ink transition-colors duration-300">
        Engagement gallery &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- CTA -->
  <!-- ============================================= -->
  <section class="text-center py-16 mb-10 reveal">
    <p class="text-[0.65rem] font-medium tracking-[0.18em] uppercase text-gold mb-3">{site.booking}</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-4">
      Let's plan your elopement.
    </h2>
    <p class="font-light text-ink-muted text-sm mb-7 max-w-md mx-auto">
      Tell me where you're dreaming of, and I'll help make it happen. Edmonton, the Rockies, or anywhere in between.
    </p>
    <a href="/contact/" class="inline-block font-medium text-[0.7rem] tracking-[0.12em] uppercase text-white bg-ink px-10 py-4 rounded-full hover:bg-[#333] transition-colors duration-300">
      Get in Touch
    </a>
  </section>

  <!-- ============================================= -->
  <!-- FAQ -->
  <!-- ============================================= -->
  <section class="max-w-2xl mx-auto mb-16 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2rem)] text-ink mb-8">
      Elopement Photography — FAQ
    </h2>
    {faqs.map((faq) => (
      <div class="faq-item border-b border-ink/[0.06] first:border-t">
        <button class="flex justify-between items-center w-full py-5 text-left cursor-pointer group" onclick="this.closest('.faq-item').classList.toggle('open')">
          <h3 class="font-normal text-[0.9rem] text-ink pr-4 leading-relaxed group-hover:text-gold-deep transition-colors">{faq.q}</h3>
          <svg class="faq-chevron w-4 h-4 text-ink-muted flex-shrink-0 transition-transform duration-500" style="transition-timing-function:cubic-bezier(0.16,1,0.3,1)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-answer"><p class="font-light text-[0.85rem] text-ink-soft leading-[1.7] pb-5 max-w-[640px]">{faq.a}</p></div>
      </div>
    ))}
  </section>

  <!-- ============================================= -->
  <!-- CROSS-LINKS -->
  <!-- ============================================= -->
  <section class="py-10 border-t border-[#e0dcd6]">
    <h2 class="font-serif font-light text-xl text-ink mb-5">Explore more</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href="/photography/weddings/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">Weddings</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">Full-day coverage</p>
      </a>
      <a href="/photography/engagement/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">Engagement</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">Couple portraits</p>
      </a>
      <a href="/wedding-photo-video-packages-edmonton/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">Photo + Video</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">Combined packages</p>
      </a>
      <a href="/pricing/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">All Packages</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">View pricing</p>
      </a>
    </div>
  </section>
</BaseLayout>
