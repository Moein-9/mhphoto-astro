---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all published posts (not drafts, not future-dated)
const now = new Date();
const allPosts = await getCollection('blog', ({ data }) => {
  if (data.draft) return false;
  const pubDate = new Date(data.publishDate || data.date);
  return pubDate <= now;
});

// Sort newest first
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const catLabels: Record<string, string> = {
  'indian-weddings': 'Indian Weddings',
  'wedding': 'Wedding',
  'wedding-tips': 'Wedding Tips',
  'wedding-planning': 'Wedding Planning',
  'family-sessions': 'Family',
  'engagement-sessions': 'Engagement',
  'edmonton-venues': 'Edmonton Venues',
  'photography-tips': 'Photography Tips',
  'lifestyle': 'Lifestyle',
};

// Collect unique categories from actual posts
const activeCats = [...new Set(posts.map(p => p.data.category))].sort();

// Featured post = newest with an image
const featured = posts.find(p => p.data.image);
const remainingPosts = posts.filter(p => p !== featured);

// Posts per page for load-more
const INITIAL_COUNT = 12;
---

<BaseLayout
  title="Blog | Wedding Tips & Inspiration | MH Photography"
  description="Wedding photography tips, Indian wedding guides, Edmonton venue reviews, and behind-the-scenes stories from MH Photography. Updated weekly."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Blog — MH Photography Edmonton",
      "description": "Wedding photography tips, Indian wedding guides, Edmonton venue reviews, and behind-the-scenes stories from MH Photography.",
      "url": "https://mhphoto.ca/blog/",
      "isPartOf": { "@type": "WebSite", "name": "MH Photography", "url": "https://mhphoto.ca" },
      "publisher": {
        "@type": "Organization",
        "name": "MH Photography",
        "url": "https://mhphoto.ca"
      },
      "mainEntity": {
        "@type": "ItemList",
        "itemListElement": posts.slice(0, 20).map((post, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "url": `https://mhphoto.ca/blog/${post.data.slug}/`,
          "name": post.data.title
        }))
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mhphoto.ca/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://mhphoto.ca/blog/" }
      ]
    })} />
  </Fragment>

  <!-- Page Header -->
  <div class="mb-12">
    <p class="text-[0.6rem] font-semibold tracking-[0.2em] uppercase text-gold mb-4">The Journal</p>
    <h1 class="font-serif font-light text-[clamp(2rem,4.5vw,3rem)] leading-[1.1] text-ink mb-4">
      Stories, tips &amp; inspiration
    </h1>
    <p class="font-light text-ink-soft text-[0.92rem] leading-[1.75] max-w-[480px]">
      Wedding planning guides, Indian ceremony photography tips, Edmonton venue spotlights, and real stories from behind the lens.
    </p>
  </div>

  <!-- Category Filter -->
  <div class="mb-10 flex flex-wrap gap-2" id="category-filters">
    <button
      class="cat-pill active text-[0.62rem] font-semibold tracking-[0.12em] uppercase px-4 py-2 rounded-full border transition-all duration-300 cursor-pointer"
      data-category="all"
    >
      All Posts
    </button>
    {activeCats.map(catSlug => (
      <button
        class="cat-pill text-[0.62rem] font-semibold tracking-[0.12em] uppercase px-4 py-2 rounded-full border transition-all duration-300 cursor-pointer"
        data-category={catSlug}
      >
        {catLabels[catSlug] || catSlug}
      </button>
    ))}
  </div>

  <!-- Featured Post -->
  {featured && (
    <a href={`/blog/${featured.data.slug}/`} class="group block mb-12" data-post data-category={featured.data.category}>
      <article class="blog-featured relative overflow-hidden rounded-lg bg-[#1a1614]">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <div class="relative aspect-[4/3] md:aspect-auto overflow-hidden">
            <img
              src={featured.data.image}
              alt={`${featured.data.title} — Edmonton wedding photography blog`}
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              loading="eager"
              fetchpriority="high"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent md:bg-none"></div>
          </div>
          <div class="flex flex-col justify-center p-8 md:p-10 lg:p-12">
            <div class="flex items-center gap-3 mb-5">
              <span class="text-[0.55rem] font-semibold tracking-[0.14em] uppercase text-gold bg-gold/10 px-2.5 py-1 rounded-full">
                {catLabels[featured.data.category] || featured.data.category}
              </span>
              <span class="text-[0.6rem] text-[#f3ede5]/40 font-light">
                {new Date(featured.data.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </div>
            <span class="text-[0.55rem] font-semibold tracking-[0.18em] uppercase text-gold/60 mb-3">Latest</span>
            <h2 class="font-serif font-light text-[clamp(1.3rem,3vw,1.85rem)] text-[#f3ede5] leading-[1.2] mb-4 group-hover:text-gold-light transition-colors duration-300">
              {featured.data.title}
            </h2>
            {featured.data.description && (
              <p class="text-[0.85rem] font-light text-[#f3ede5]/55 leading-[1.7] line-clamp-3 mb-6">
                {featured.data.description}
              </p>
            )}
            <span class="inline-flex items-center gap-2 text-[0.68rem] font-medium tracking-[0.1em] uppercase text-gold group-hover:gap-3 transition-all duration-300">
              Read Article
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </div>
      </article>
    </a>
  )}

  <!-- Blog Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-5 gap-y-10 mb-12" id="posts-grid">
    {remainingPosts.map((post, i) => {
      const cat = catLabels[post.data.category] || post.data.category;
      const date = new Date(post.data.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' });
      const hidden = i >= INITIAL_COUNT;
      return (
        <a
          href={`/blog/${post.data.slug}/`}
          class:list={['group block blog-card', { 'hidden': hidden }]}
          data-post
          data-category={post.data.category}
          data-index={i}
        >
          <article>
            {post.data.image ? (
              <div class="aspect-[4/3] rounded-sm overflow-hidden mb-4 bg-cream-warm">
                <img
                  src={post.data.image}
                  alt={`${post.data.title} — Edmonton wedding photography blog by MH Photography`}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-[4/3] rounded-sm mb-4 bg-cream-warm flex items-center justify-center">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-ink-muted/30">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="m21 15-5-5L5 21"/>
                </svg>
              </div>
            )}
            <div class="flex items-center gap-2.5 mb-2.5">
              <span class="text-[0.55rem] font-semibold tracking-[0.14em] uppercase text-gold">
                {cat}
              </span>
              <span class="w-[3px] h-[3px] rounded-full bg-ink-muted/30"></span>
              <span class="text-[0.62rem] text-ink-muted font-light">{date}</span>
            </div>
            <h2 class="font-serif font-light text-[1.02rem] text-ink leading-[1.35] group-hover:text-gold-deep transition-colors duration-300 line-clamp-2 mb-2">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-[0.78rem] font-light text-ink-soft leading-[1.65] line-clamp-2">
                {post.data.description}
              </p>
            )}
          </article>
        </a>
      );
    })}
  </div>

  <!-- Load More -->
  {remainingPosts.length > INITIAL_COUNT && (
    <div class="text-center mb-16" id="load-more-wrap">
      <button
        id="load-more-btn"
        class="inline-flex items-center gap-2 text-[0.7rem] font-medium tracking-[0.12em] uppercase text-ink border border-[#e0dcd6] px-8 py-3.5 rounded-full hover:border-gold/50 hover:text-gold transition-all duration-300 cursor-pointer"
      >
        Load More Articles
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <p class="text-[0.65rem] text-ink-muted/50 mt-3" id="post-count">
        Showing <span id="visible-count">{Math.min(INITIAL_COUNT, remainingPosts.length)}</span> of {remainingPosts.length} articles
      </p>
    </div>
  )}

  <!-- Newsletter / CTA -->
  <div class="relative overflow-hidden rounded-lg bg-[#1a1614] p-10 md:p-14 text-center mb-16">
    <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-gold/5 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="relative">
      <p class="font-serif font-light text-[clamp(1.3rem,3vw,1.75rem)] text-[#f3ede5] mb-3 leading-[1.3]">
        Looking for a photographer?
      </p>
      <p class="text-[0.85rem] font-light text-[#f3ede5]/55 mb-7 max-w-[420px] mx-auto leading-[1.7]">
        I would love to hear about your wedding, engagement, or family session. Let's create something beautiful together.
      </p>
      <a href="/contact/" class="inline-block font-medium text-[0.7rem] tracking-[0.14em] uppercase text-[#1a1614] bg-gold px-8 py-3.5 rounded-full hover:bg-gold-light transition-colors duration-300">
        Get in Touch
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  /* --- Category Pills --- */
  .cat-pill {
    color: var(--color-ink-muted);
    border-color: #e0dcd6;
    background: transparent;
  }
  .cat-pill:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
  .cat-pill.active {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: #f3ede5;
  }

  /* --- Line clamp --- */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* --- Card hover lift --- */
  .blog-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .blog-card:hover {
    transform: translateY(-4px);
  }

  /* --- Fade-in for load-more cards --- */
  .blog-card.fade-in {
    animation: cardFadeIn 0.5s ease-out forwards;
  }
  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- Featured post responsive --- */
  .blog-featured {
    transition: box-shadow 0.4s ease;
  }
  .blog-featured:hover {
    box-shadow: 0 20px 60px rgba(0,0,0,0.12);
  }
</style>

<script define:vars={{ INITIAL_COUNT }}>
  // Category filter
  const pills = document.querySelectorAll('.cat-pill');
  const allPostEls = document.querySelectorAll('[data-post]');
  const loadMoreWrap = document.getElementById('load-more-wrap');
  const loadMoreBtn = document.getElementById('load-more-btn');
  const visibleCountEl = document.getElementById('visible-count');

  let currentCategory = 'all';
  let loadedCount = INITIAL_COUNT;

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      // Update active pill
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');

      currentCategory = pill.getAttribute('data-category') || 'all';
      applyFilter();
    });
  });

  function applyFilter() {
    let visibleIndex = 0;

    allPostEls.forEach(el => {
      const cat = el.getAttribute('data-category');
      const isMatch = currentCategory === 'all' || cat === currentCategory;

      if (isMatch) {
        el.classList.remove('hidden');
        visibleIndex++;
      } else {
        el.classList.add('hidden');
      }
    });

    // Hide load-more when filtering
    if (loadMoreWrap) {
      loadMoreWrap.style.display = currentCategory === 'all' ? '' : 'none';
    }

    // When filtering, show all matching posts (no pagination)
    if (currentCategory !== 'all') {
      allPostEls.forEach(el => {
        const cat = el.getAttribute('data-category');
        if (cat === currentCategory) {
          el.classList.remove('hidden');
        }
      });
    } else {
      // Re-apply pagination for "all"
      const gridCards = document.querySelectorAll('#posts-grid [data-post]');
      gridCards.forEach((el, i) => {
        if (i >= loadedCount) {
          el.classList.add('hidden');
        } else {
          el.classList.remove('hidden');
        }
      });
      updateCount();
    }
  }

  function updateCount() {
    const gridCards = document.querySelectorAll('#posts-grid [data-post]');
    const visible = Math.min(loadedCount, gridCards.length);
    if (visibleCountEl) visibleCountEl.textContent = String(visible);
    if (loadMoreWrap && loadedCount >= gridCards.length) {
      loadMoreWrap.style.display = 'none';
    }
  }

  // Load more
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', () => {
      const gridCards = document.querySelectorAll('#posts-grid [data-post]');
      const nextBatch = Math.min(loadedCount + 9, gridCards.length);

      for (let i = loadedCount; i < nextBatch; i++) {
        gridCards[i].classList.remove('hidden');
        gridCards[i].classList.add('fade-in');
      }

      loadedCount = nextBatch;
      updateCount();
    });
  }

  // Check URL for category filter
  const params = new URLSearchParams(window.location.search);
  const urlCat = params.get('category');
  if (urlCat) {
    const targetPill = document.querySelector(`.cat-pill[data-category="${urlCat}"]`);
    if (targetPill) {
      targetPill.click();
    }
  }
</script>
