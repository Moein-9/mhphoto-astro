<script>
  (function() {
    // Reading progress bar — throttled via rAF to prevent jank on mobile
    var progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      var article = document.querySelector('.blog-article');
      if (article) {
        var progressTicking = false;
        var updateProgress = function() {
          var rect = article.getBoundingClientRect();
          var articleTop = rect.top + window.scrollY;
          var articleHeight = rect.height;
          var denominator = articleHeight - window.innerHeight;
          // Guard against division by zero (very short articles or large viewports)
          if (denominator <= 0) {
            progressBar.style.width = '100%';
            return;
          }
          var scrolled = window.scrollY - articleTop;
          var progress = Math.min(100, Math.max(0, (scrolled / denominator) * 100));
          progressBar.style.width = progress + '%';
        };
        window.addEventListener('scroll', function() {
          if (!progressTicking) {
            progressTicking = true;
            requestAnimationFrame(function() {
              updateProgress();
              progressTicking = false;
            });
          }
        }, { passive: true });
        updateProgress();
      }
    }

    // Copy link button
    var copyBtn = document.getElementById('copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(window.location.href).then(function() {
              var svg = copyBtn.querySelector('svg');
              if (svg) {
                var original = svg.innerHTML;
                svg.innerHTML = '<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2"/>';
                copyBtn.classList.add('!text-gold', '!border-gold/40');
                setTimeout(function() {
                  svg.innerHTML = original;
                  copyBtn.classList.remove('!text-gold', '!border-gold/40');
                }, 2000);
              }
            }).catch(function() {});
          }
        } catch (e) {
          // Fallback: do nothing on older browsers
        }
      });
    }
  })();
</script>
