        { "@type": "Question", "name": "What style of wedding videos do you create?", "acceptedAnswer": { "@type": "Answer", "text": "Our wedding films are documentary-style and cinematic. We mix media — cinematic camera work, film-style textures, and camcorder-inspired moments. Every film feels like your day, not a music video." }},
        { "@type": "Question", "name": "Do you film Indian and South Asian weddings?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We have extensive experience filming Hindu, Sikh, Punjabi, and multi-day South Asian weddings across Edmonton and Alberta." }},
        { "@type": "Question", "name": "How long is the wedding film?", "acceptedAnswer": { "@type": "Answer", "text": "A standard highlight video runs 4-5 minutes. Extended highlights go up to 15 minutes. Ceremony and reception footage is delivered separately." }},
        { "@type": "Question", "name": "Do you travel outside Edmonton for wedding videography?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — we cover weddings across Alberta including Calgary, Banff, Jasper, Sherwood Park, St. Albert, Spruce Grove, and beyond." }},
      ],
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Wedding Videography Edmonton",
      "description": "Cinematic documentary-style wedding films by MH Photography in Edmonton. Highlight videos, ceremony and reception edits, multi-day Indian wedding videography.",
