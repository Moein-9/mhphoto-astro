  <!-- 5-card montage script -->
  <script define:vars={{ allIds: videos.map(v => v.id) }}>
    (function() {
      const cards = document.querySelectorAll('.montage-card');
      if (!cards.length) return;

      // Each card gets a different shuffled order and different timing
      const timings = [4000, 6500, 3500, 5000, 7000]; // all different
      const startOffsets = [10, 45, 25, 60, 35, 15, 50]; // variety of start points

      cards.forEach((card, cardIdx) => {
        const frames = card.querySelectorAll('.mc-frame');
        if (frames.length < 2) return;

        // Shuffle video order differently for each card
        const order = [...allIds];
        for (let i = order.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [order[i], order[j]] = [order[j], order[i]];
        }
        // Offset each card so they don't start on the same video
        const shifted = [...order.slice(cardIdx % order.length), ...order.slice(0, cardIdx % order.length)];

        let current = 0;
        let activeIdx = 0;

        function buildSrc(vidIdx) {
          const id = shifted[vidIdx % shifted.length];
          const start = startOffsets[(vidIdx + cardIdx) % startOffsets.length];
          return `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&mute=1&controls=0&showinfo=0&rel=0&modestbranding=1&start=${start}`;
        }

        // Load first clip
        frames[0].src = buildSrc(0);

        function cycle() {
          current++;
          const nextFrame = activeIdx === 0 ? 1 : 0;
          frames[nextFrame].src = buildSrc(current);
          setTimeout(() => {
            frames[nextFrame].classList.add('mc-active');
            frames[activeIdx].classList.remove('mc-active');
            activeIdx = nextFrame;
          }, 600);
        }

        // Stagger start so they don't all begin cycling at the same time
        const initialDelay = cardIdx * 1200 + Math.random() * 1000;
        setTimeout(() => {
          setInterval(cycle, timings[cardIdx % timings.length]);
        }, initialDelay);
      });
    })();
  </script>

  <!-- Montage script — cycles hero between clips -->
  <script define:vars={{ montageIds: videos.map(v => v.id) }}>
    (function() {
      const ids = montageIds;
      const CLIP_DURATION = 3000; // 3 seconds per clip
      const PRELOAD_BEFORE = 800; // preload next 0.8s before switch
      // Each clip starts at a different interesting timestamp
      const starts = [15, 20, 30, 10, 25, 35, 18];

      const frameA = document.getElementById('hero-a');
      const frameB = document.getElementById('hero-b');
      const progressBar = document.getElementById('montage-progress');
      if (!frameA || !frameB) return;

      let current = 0;
      let activeFrame = 'a'; // which frame is visible

      function buildSrc(idx) {
        const id = ids[idx % ids.length];
        const start = starts[idx % starts.length];
        return `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&autoplay=1&mute=1&controls=0&showinfo=0&start=${start}`;
      }

      function nextClip() {
        current++;
        const nextIdx = current % ids.length;

        if (activeFrame === 'a') {
          // Load into B, then crossfade
          frameB.src = buildSrc(nextIdx);
          setTimeout(() => {
            frameB.classList.add('active');
            frameA.classList.remove('active');
            activeFrame = 'b';
          }, PRELOAD_BEFORE);
        } else {
          frameA.src = buildSrc(nextIdx);
          setTimeout(() => {
            frameA.classList.add('active');
            frameB.classList.remove('active');
            activeFrame = 'a';
          }, PRELOAD_BEFORE);
        }

        // Restart progress bar
        if (progressBar) {
          progressBar.style.transition = 'none';
          progressBar.style.width = '0%';
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              progressBar.style.transition = `width ${CLIP_DURATION}ms linear`;
              progressBar.style.width = '100%';
            });
          });
        }
      }

      // Start progress bar for first clip
      if (progressBar) {
        progressBar.style.transition = `width ${CLIP_DURATION}ms linear`;
        progressBar.style.width = '100%';
      }

      // Only run montage when hero is visible
      let interval;
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          if (!interval) interval = setInterval(nextClip, CLIP_DURATION);
        } else {
          if (interval) { clearInterval(interval); interval = null; }
        }
      }, { threshold: 0.3 });

      const heroWrap = frameA.closest('.hero-video-wrap');
      if (heroWrap) observer.observe(heroWrap);
    })();
  </script>

  <!-- Thumbnail swap script -->
  <script>
    const thumbs = document.querySelectorAll('.video-thumb');
    const mainIframe = document.getElementById('main-iframe') as HTMLIFrameElement;
    const mainTitle = document.getElementById('main-title');
    const mainVenue = document.getElementById('main-venue');
    const mainType = document.getElementById('main-type');

    thumbs.forEach(thumb => {
      thumb.addEventListener('click', () => {
        const id = thumb.getAttribute('data-id');
        const title = thumb.getAttribute('data-title');
        const venue = thumb.getAttribute('data-venue');
        const type = thumb.getAttribute('data-type');

        // Swap main player — autoplay with sound this time (user clicked)
        if (mainIframe) mainIframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
        if (mainTitle) mainTitle.textContent = title;
        if (mainVenue) mainVenue.textContent = `${venue} — MH Photography`;
        if (mainType) mainType.textContent = type;

        // Update ring styles
        thumbs.forEach(t => {
          t.classList.remove('ring-2', 'ring-gold', 'ring-offset-2', 'ring-offset-cream');
          t.classList.add('ring-1', 'ring-ink/10');
          const badge = t.querySelector('[class*="bg-gold"]');
          if (badge && badge.textContent?.includes('Now Playing')) badge.remove();
        });
        thumb.classList.remove('ring-1', 'ring-ink/10');
        thumb.classList.add('ring-2', 'ring-gold', 'ring-offset-2', 'ring-offset-cream');

        // Scroll to player
        document.getElementById('main-player')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  </script>
</BaseLayout>

<style>
  .hero-video-wrap {
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
  }

  /* Montage crossfade */
  .montage-frame {
    opacity: 0;
    transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 1;
  }
  .montage-frame.active {
    opacity: 1;
    z-index: 2;
  }

  /* Progress bar */
  .montage-bar {
    width: 0%;
  }

  /* 5-card montage frames */
  .mc-frame {
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
    border: none;
    pointer-events: none;
  }
  .mc-frame.mc-active {
    opacity: 1;
    z-index: 2;
  }
  .montage-card {
    transition: transform 0.3s ease;
  }
  .montage-card:hover {
    transform: translateY(-3px);
  }
</style>
