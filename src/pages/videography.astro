      "@type": "WebPage",
      "name": "Edmonton Wedding Videographer | Cinematic Wedding Films",
      "description": "Cinematic documentary-style wedding films from Edmonton wedding videographer Moein Habibi.",
      "url": "https://mhphoto.ca/videography/",
      "author": { "@type": "Person", "name": "Moein Habibi" },
      "mainEntity": videos.map(v => ({
        "@type": "VideoObject",
        "name": v.title + " — Edmonton wedding videography by MH Photography",
        "description": `${v.type} videography in ${v.venue} by MH Photography Edmonton`,
        "thumbnailUrl": `https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`,
        "embedUrl": `https://www.youtube-nocookie.com/embed/${v.id}`,
        "uploadDate": "2025-01-01",
      })),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How much does a wedding videographer in Edmonton cost?", "acceptedAnswer": { "@type": "Answer", "text": "Wedding videography packages at MH Photography start at $3,750 for single-day coverage. Photo and video bundles start at $8,750. Multi-day Indian wedding videography packages are available with custom pricing." }},
