---
import BaseLayout from '../layouts/BaseLayout.astro';
import { packages, priceUpdatedDate } from '../data/pricing';
import { site } from '../data/site';
---

<BaseLayout
  title="Wedding Photo & Video Packages | MH Photography"
  description="Edmonton wedding photography from $2,250. Videography from $3,750. Photo + video bundles from $8,750. Family sessions from $400. View all packages."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "MH Photography — Wedding Photography & Videography Packages",
      "description": "Edmonton wedding photography, videography, and photo+video packages. Family sessions also available.",
      "url": "https://mhphoto.ca/pricing/",
      "serviceType": "Wedding Photography and Videography",
      "areaServed": {
        "@type": "City",
        "name": "Edmonton",
        "containedInPlace": { "@type": "AdministrativeArea", "name": "Alberta, Canada" }
      },
      "provider": {
        "@type": "PhotographyBusiness",
        "name": "MH Photography",
        "url": "https://mhphoto.ca",
        "email": "moein@mhphoto.ca",
        "address": { "@type": "PostalAddress", "addressLocality": "Edmonton", "addressRegion": "AB", "addressCountry": "CA" }
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Photography & Videography Packages",
        "itemListElement": [
          {
            "@type": "OfferCatalog",
            "name": "Wedding Photography",
            "itemListElement": [
              { "@type": "Offer", "name": "Single-day Wedding Photography", "priceCurrency": "CAD", "price": "2250", "description": "Full-day documentary wedding photography coverage", "url": "https://mhphoto.ca/pricing/" },
              { "@type": "Offer", "name": "Multi-day Wedding Photography", "priceCurrency": "CAD", "price": "6490", "description": "Multi-day wedding photography for Indian and South Asian celebrations", "url": "https://mhphoto.ca/pricing/" }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "Wedding Videography",
            "itemListElement": [
              { "@type": "Offer", "name": "Single-day Wedding Videography", "priceCurrency": "CAD", "price": "3750", "description": "Cinematic wedding film with highlight video", "url": "https://mhphoto.ca/pricing/" },
              { "@type": "Offer", "name": "Multi-day Wedding Videography", "priceCurrency": "CAD", "price": "7490", "description": "Multi-day cinematic wedding videography coverage", "url": "https://mhphoto.ca/pricing/" }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "Photo + Video Packages",
            "itemListElement": [
              { "@type": "Offer", "name": "Single-day Photo + Video", "priceCurrency": "CAD", "price": "8750", "description": "Complete photography and videography from one team", "url": "https://mhphoto.ca/pricing/" },
              { "@type": "Offer", "name": "Multi-day Photo + Video", "priceCurrency": "CAD", "price": "17990", "description": "Multi-day combined photo and video coverage", "url": "https://mhphoto.ca/pricing/" }
            ]
          },
          {
            "@type": "OfferCatalog",
            "name": "Family Sessions",
            "itemListElement": [
              { "@type": "Offer", "name": "Family Photography Session", "priceCurrency": "CAD", "price": "400", "description": "One-hour outdoor family session with 30+ edited images", "url": "https://mhphoto.ca/pricing/" }
            ]
          }
        ]
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mhphoto.ca/" },
        { "@type": "ListItem", "position": 2, "name": "Packages & Pricing", "item": "https://mhphoto.ca/pricing/" }
      ]
    })} />
  </Fragment>
  <!-- Hero -->
  <div class="mb-10 md:mb-14">
    <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-4">{site.booking}</p>
    <h1 class="font-serif font-light text-[clamp(1.75rem,4vw,2.75rem)] leading-[1.1] text-ink mb-5">
      Packages & pricing
    </h1>
    <p class="font-light text-ink-soft text-[0.95rem] leading-[1.8] max-w-[520px]">
      Every package includes professional editing, an online gallery, and full download rights.
      Custom quotes available for unique celebrations.
    </p>
  </div>

  <!-- Package Cards Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-14">
    {packages.map((pkg) => (
      <div class:list={[
        'pkg-card rounded-2xl overflow-hidden transition-all duration-400',
        pkg.highlight
          ? 'ring-2 ring-gold/30 shadow-lg'
          : 'ring-1 ring-black/5 shadow-sm hover:shadow-md',
      ]}>
        <!-- Card Image -->
        <div class="relative h-[220px] sm:h-[260px] overflow-hidden">
          <img
            src={pkg.image}
            alt={`${pkg.name} — Edmonton photography packages by MH Photography`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          {pkg.highlight && (
            <span class="absolute top-3 right-3 text-[0.55rem] font-semibold tracking-[0.12em] uppercase text-white bg-gold/90 backdrop-blur-sm px-3 py-1 rounded-full">
              Most Popular
            </span>
          )}
        </div>

        <!-- Card Body -->
        <div class="p-5 sm:p-6 bg-white">
          <!-- Title -->
          <h2 class="font-serif font-light text-lg text-gold-warm text-center tracking-wide uppercase mb-0.5">
            {pkg.name}
          </h2>
          <p class="text-[0.75rem] text-ink-muted text-center font-light mb-4">
            {pkg.subtitle}
          </p>

          <!-- Description -->
          <p class="text-[0.8rem] font-light text-ink-soft text-center leading-relaxed mb-5 px-2">
            {pkg.description}
          </p>

          <!-- Price Rows -->
          <div class="space-y-3 mb-5">
            {pkg.prices.map((p) => (
              <div class="flex items-center gap-3 bg-[#f7f5f2] rounded-xl px-4 py-3">
                <div class="w-9 h-9 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-gold-warm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2" />
                    <path d="M16 3v4M8 3v4" />
                    <circle cx="12" cy="15" r="2" />
                  </svg>
                </div>
                <div>
                  <p class="text-[0.7rem] text-ink-muted font-light leading-tight">{p.label}</p>
                  <p class="text-lg font-serif font-light text-ink">{p.price}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Note (if exists) -->
          {pkg.note && (
            <p class="text-[0.75rem] font-light text-ink-soft italic text-center leading-relaxed mb-5 px-2">
              {pkg.note}
            </p>
          )}

          <!-- CTA Button -->
          <a
            href="/contact/"
            class:list={[
              'block text-center font-semibold text-[0.7rem] tracking-[0.14em] uppercase py-3 rounded-full transition-all duration-300 mb-3',
              pkg.highlight
                ? 'bg-ink text-white hover:bg-[#333]'
                : 'bg-white text-ink border border-ink/20 hover:bg-ink hover:text-white',
            ]}
          >
            Let's Talk
          </a>

          <!-- Updated Date -->
          <p class="text-[0.6rem] text-ink-muted/50 text-center font-light italic">
            Price was updated on {priceUpdatedDate}
          </p>
        </div>
      </div>
    ))}
  </div>

  <!-- What's Included Section -->
  <section class="border-t border-[#e0dcd6] pt-10 mb-10">
    <h2 class="font-serif font-light text-xl text-ink mb-6 text-center">What's included in every package</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {[
        { icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', label: 'Professional Editing' },
        { icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10', label: 'Full Downloads' },
        { icon: 'M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z M15 13a3 3 0 11-6 0 3 3 0 016 0z', label: 'Online Gallery' },
        { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Quick Turnaround' },
      ].map((item) => (
        <div class="text-center p-4 rounded-xl bg-[#f7f5f2]">
          <svg class="w-6 h-6 mx-auto mb-2 text-gold-warm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d={item.icon} />
          </svg>
          <p class="text-[0.7rem] font-medium text-ink">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Custom Quote CTA -->
  <section class="text-center py-10 border-t border-[#e0dcd6]">
    <h2 class="font-serif font-light text-xl text-ink mb-3">Something more custom?</h2>
    <p class="font-light text-ink-soft text-[0.85rem] mb-6 max-w-md mx-auto leading-relaxed">
      Every celebration is unique. Reach out with your details and I'll put together a package that fits perfectly.
    </p>
    <a href="/contact/" class="inline-flex items-center gap-2 text-[0.8rem] font-medium tracking-[0.05em] text-white bg-ink px-7 py-3 rounded-full hover:bg-[#333] transition-all duration-300">
      Get a Custom Quote
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</BaseLayout>

<style>
  .pkg-card {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
  }
  .pkg-card:hover {
    transform: translateY(-4px);
  }
</style>
