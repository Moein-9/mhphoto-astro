---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | MH Photography"
  description="The page you're looking for doesn't exist. Let's get you back on track."
>
  <div class="flex flex-col items-center justify-center text-center py-20 sm:py-32">
    <p class="text-[0.6rem] font-medium tracking-[0.2em] uppercase text-gold mb-6">Page Not Found</p>
    <h1 class="font-serif font-light text-[clamp(3rem,8vw,5rem)] leading-[1] text-ink mb-4">404</h1>
    <p class="font-light text-ink-soft text-[0.95rem] leading-[1.8] max-w-[420px] mb-10">
      This page doesn't exist or may have moved. Let's get you somewhere beautiful instead.
    </p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/"
        class="font-semibold text-[0.68rem] tracking-[0.14em] uppercase text-white bg-ink px-8 py-3.5 rounded-full hover:bg-[#333] transition-colors duration-300">
        Back to Home
      </a>
      <a href="/photography/"
        class="font-semibold text-[0.68rem] tracking-[0.14em] uppercase text-ink bg-transparent px-8 py-3.5 rounded-full border border-ink/20 hover:bg-ink hover:text-white transition-all duration-300">
        View Portfolio
      </a>
    </div>
  </div>
</BaseLayout>
