---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="About Moein Habibi | Edmonton Wedding Photographer"
  description="Meet Moe — Edmonton's documentary wedding photographer and filmmaker. Over 200 weddings captured, Indian wedding specialist. Book 2026 & 2027."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "name": "About Moein Habibi — MH Photography Edmonton",
      "url": "https://mhphoto.ca/about/",
      "dateCreated": "2026-04-04",
      "dateModified": "2026-04-04",
      "mainEntity": {
        "@type": "Person",
        "name": "Moein Habibi",
        "alternateName": "Moe Habibi",
        "jobTitle": "Wedding Photographer & Filmmaker",
        "description": "Documentary wedding photographer and filmmaker based in Edmonton, Alberta. Over 200 weddings captured. Indian and South Asian wedding specialist.",
        "url": "https://mhphoto.ca/about/",
        "image": "https://mhphoto.ca/images/about-moe.jpg",
        "worksFor": {
          "@type": "LocalBusiness",
          "name": "MH Photography",
          "url": "https://mhphoto.ca"
        },
        "knowsAbout": ["Wedding Photography", "Wedding Videography", "Indian Wedding Photography", "Family Photography", "Documentary Photography", "Cinematic Wedding Films"],
        "address": { "@type": "PostalAddress", "addressLocality": "Edmonton", "addressRegion": "AB", "addressCountry": "CA" },
        "sameAs": [
          "https://www.instagram.com/mhphotoss",
          "https://www.youtube.com/@MoeinHabibi",
          "https://www.facebook.com/MoeinHphotography"
        ]
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mhphoto.ca/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://mhphoto.ca/about/" }
      ]
    })} />
  </Fragment>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-16 items-start">
    <!-- Photo -->
    <div class="lg:sticky lg:top-24">
      <div class="rounded-lg overflow-hidden aspect-square">
        <img src="/images/about-moe.jpg" alt="Moein Habibi — Edmonton wedding photographer and filmmaker at MH Photography" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="960" height="954" />
      </div>
      <div class="mt-6 flex items-center gap-4">
        <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="text-xs font-medium tracking-[0.1em] uppercase text-[#999] hover:text-[#1a1a1a] transition-colors">Instagram</a>
        <span class="text-[#ddd]">|</span>
        <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="text-xs font-medium tracking-[0.1em] uppercase text-[#999] hover:text-[#1a1a1a] transition-colors">YouTube</a>
        <span class="text-[#ddd]">|</span>
        <a href={`mailto:${site.email}`} class="text-xs font-medium tracking-[0.1em] uppercase text-[#999] hover:text-[#1a1a1a] transition-colors">Email</a>
      </div>
    </div>

    <!-- Bio -->
    <div>
      <p class="text-xs font-medium tracking-[0.2em] uppercase text-gold mb-4">About</p>
      <h1 class="font-serif font-light text-[clamp(2rem,4vw,3rem)] leading-[1.1] text-[#1a1a1a] mb-8">
        Hi, I'm Moe.
      </h1>

      <div class="space-y-5 font-light text-[#555] text-[0.95rem] leading-[1.8]">
        <p>
          I'm Moein Habibi — most people call me Moe. I'm a documentary wedding photographer and filmmaker based in Edmonton, Alberta. I've been doing this for over 15 years, and I still get that rush when I capture something real.
        </p>
        <p>
          My approach is simple: I stay close, move quietly, and photograph your day as it actually happens. I'm not going to pull you away from your guests for an hour of stiff posed shots. The nervous laugh before the ceremony, your dad trying not to cry, that split second when you see each other for the first time — those are the moments I'm after.
        </p>
        <p>
          I handle both photography and videography myself. Same eye, same style, zero coordination stress between vendors. Your photos and film feel like they belong together because they were made by the same person who was there for all of it.
        </p>
        <p>
          I have a deep love for Indian and South Asian wedding traditions. I've spent years photographing Hindu ceremonies, Anand Karaj at Gurdwaras, and Punjabi celebrations across Edmonton. I understand the flow, the timing, the emotional beats — and I know when to step back and when to be close.
        </p>
        <p>
          When I'm not behind the camera, I'm probably editing in my studio with too much coffee, or planning my next trip. I believe photography should feel effortless — for you and for me.
        </p>
      </div>

      <div class="mt-12 pt-8 border-t border-[#e0dcd6]">
        <h2 class="font-serif font-light text-xl text-[#1a1a1a] mb-4">Let's work together.</h2>
        <p class="font-light text-[#666] text-sm mb-6">
          I take on a limited number of weddings each year so every couple gets the attention they deserve.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/contact/" class="inline-block font-medium text-[0.7rem] tracking-[0.12em] uppercase text-white bg-[#1a1a1a] px-8 py-3.5 rounded-full hover:bg-[#333] transition-colors duration-300">
            Get in Touch
          </a>
          <a href="/photography/" class="inline-block font-medium text-[0.7rem] tracking-[0.12em] uppercase text-[#1a1a1a] border border-[#1a1a1a]/20 px-6 py-3.5 rounded-full hover:bg-[#1a1a1a] hover:text-white transition-all duration-300">
            View Portfolio
          </a>
          <a href="/videography/" class="inline-block font-medium text-[0.7rem] tracking-[0.12em] uppercase text-[#1a1a1a] border border-[#1a1a1a]/20 px-6 py-3.5 rounded-full hover:bg-[#1a1a1a] hover:text-white transition-all duration-300">
            Watch Films
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
