---
import BaseLayout from '../layouts/BaseLayout.astro';
import { multidayPackages, addOns } from '../data/hidden-packages';
import { site } from '../data/site';

const categoryImages = [
  '/images/hero/indian-haldi.jpg',
  '/images/hero/indian-ritual.jpg',
  '/images/hero/indian-couple.jpg',
];
---

<BaseLayout
  title="Multi-Day Indian Wedding Packages | MH Photography Edmonton"
  description="Multi-day wedding photography from $6,490. Videography from $7,490. Photo + video from $17,990. Indian, Sikh, Hindu & South Asian celebrations."
  noindex={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Multi-Day Indian Wedding Packages — MH Photography Edmonton",
      "description": "Multi-day photo and video packages for Indian, Sikh, Hindu, and South Asian weddings in Edmonton and Alberta.",
      "url": "https://mhphoto.ca/multiday-packages/",
      "provider": { "@type": "LocalBusiness", "name": "MH Photography", "url": "https://mhphoto.ca" },
      "areaServed": [
        { "@type": "City", "name": "Edmonton" },
        { "@type": "AdministrativeArea", "name": "Alberta" }
      ],
      "offers": [
        { "@type": "Offer", "name": "Multi-day Photography", "priceCurrency": "CAD", "price": "6490" },
        { "@type": "Offer", "name": "Multi-day Videography", "priceCurrency": "CAD", "price": "7490" },
        { "@type": "Offer", "name": "Multi-day Photo + Video", "priceCurrency": "CAD", "price": "17990" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mhphoto.ca/" },
        { "@type": "ListItem", "position": 2, "name": "Multi-Day Packages", "item": "https://mhphoto.ca/multiday-packages/" }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <div class="mb-6">
    <a href="/" class="text-[0.7rem] font-light text-ink-muted hover:text-gold transition-colors">&larr; Back to MH Photography</a>
  </div>

  <div class="relative rounded-2xl overflow-hidden mb-14">
    <img src="/images/hero/indian-anand-karaj.jpg" alt="Indian wedding Anand Karaj ceremony — Edmonton multi-day wedding photography by MH Photography" class="w-full h-[280px] sm:h-[340px] object-cover" loading="eager" fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-10">
      <p class="text-[0.6rem] font-medium tracking-[0.2em] uppercase text-gold-light mb-3">{site.booking}</p>
      <h1 class="font-serif font-light text-[clamp(1.75rem,4vw,2.75rem)] text-white leading-tight mb-3">
        Multi-Day Wedding Packages
      </h1>
      <p class="font-light text-white/70 text-[0.85rem] leading-relaxed max-w-[500px]">
        Built for Indian, Sikh, Hindu, Punjabi, and multi-day celebrations.
        Pre-wedding events through reception — every moment covered.
      </p>
    </div>
  </div>

  <!-- Package Categories -->
  {multidayPackages.map((cat, catIdx) => (
    <section class="mb-20">
      <div class="cat-header rounded-2xl p-6 sm:p-8 mb-6 text-center">
        <h2 class="font-serif font-light text-[clamp(1.75rem,4vw,2.5rem)] text-ink mb-1">{cat.title}</h2>
        <p class="text-[0.7rem] font-medium tracking-[0.15em] uppercase text-gold mb-4">{cat.subtitle}</p>
        <p class="text-[0.8rem] font-light text-ink-soft italic max-w-[420px] mx-auto">{cat.note}</p>
      </div>

      <!-- Swipeable Cards -->
      <div class="flex gap-5 overflow-x-auto pb-6 -mx-6 px-6 snap-x snap-mandatory scrollbar-hide" style="scroll-behavior:smooth">
        {cat.packages.map((pkg) => (
          <div class:list={[
            'pkg-card flex-shrink-0 w-[280px] sm:w-[300px] snap-center rounded-2xl overflow-hidden bg-white shadow-md flex flex-col',
            pkg.popular ? 'ring-2 ring-gold/30 shadow-lg' : 'ring-1 ring-ink/5',
          ]}>
            <div class="p-6 pb-5 card-header-glow border-b border-[#e8e4de] relative">
              {pkg.popular && (
                <span class="absolute top-4 right-4 text-[0.5rem] font-bold tracking-[0.12em] uppercase bg-gold text-white px-2.5 py-1 rounded-full shadow-sm">
                  Recommended
                </span>
              )}
              <p class="text-[0.6rem] font-medium tracking-[0.15em] uppercase text-gold mb-1.5">{cat.title}</p>
              <h3 class="font-serif font-light text-lg text-ink mb-3">{pkg.name}</h3>
              <p class="font-serif text-[2.25rem] font-light text-ink leading-none">{pkg.price}</p>
            </div>

            <div class="p-6 flex flex-col flex-grow">
              <ul class="space-y-3 mb-6 flex-grow">
                {pkg.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-[0.8rem] font-light text-ink-soft">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20 6L9 17l-5-5"/>
                    </svg>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>

              <a href="/contact/" class:list={[
                'block text-center font-semibold text-[0.7rem] tracking-[0.12em] uppercase py-3.5 rounded-full transition-all duration-300',
                pkg.popular
                  ? 'bg-ink text-white hover:bg-[#333] shadow-sm'
                  : 'bg-transparent text-ink border border-ink/20 hover:bg-ink hover:text-white',
              ]}>
                Let's Talk
              </a>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-[0.6rem] text-ink-muted/40 mt-1 sm:hidden">Swipe to see more &rarr;</p>
    </section>
  ))}

  <!-- Add-Ons -->
  <section class="mb-14">
    <div class="text-center mb-8">
      <h2 class="font-serif font-light text-2xl text-ink mb-1">Add-Ons</h2>
      <p class="text-[0.7rem] font-light text-gold tracking-wide">Customize your package</p>
    </div>
    <!-- Highlight callout -->
    <div class="bg-gold/5 border border-gold/20 rounded-xl p-5 mb-6 text-center">
      <p class="text-[0.8rem] font-medium text-ink mb-1">Want a next-day slideshow or highlight film at your reception?</p>
      <p class="text-[0.75rem] font-light text-ink-soft">Next-day edits are available as add-ons for both video and photo+video packages. See pricing below.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {addOns.map((addon) => {
        const isHighlight = addon.name.includes('Next-day');
        return (
          <div class:list={[
            'flex items-center justify-between p-5 rounded-xl shadow-sm',
            isHighlight ? 'bg-gold/5 ring-2 ring-gold/20' : 'bg-white ring-1 ring-ink/5',
          ]}>
            <div class="pr-4">
              <p class="text-[0.8rem] font-light text-ink leading-snug">{addon.name}</p>
              {isHighlight && <span class="text-[0.6rem] font-medium tracking-wide uppercase text-gold">Popular Add-On</span>}
            </div>
            <p class="font-serif font-light text-lg text-gold whitespace-nowrap">{addon.price}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- About Me Section -->
  <section class="mb-16 py-10 border-t border-[#e0dcd6]">
    <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-8 items-start">
      <div class="mx-auto sm:mx-0">
        <div class="w-[160px] h-[200px] rounded-xl overflow-hidden">
          <img src="/images/about-moe.jpg" alt="Moein Habibi — Edmonton Indian wedding photographer specializing in multi-day celebrations" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
      <div>
        <p class="text-[0.65rem] font-medium tracking-[0.15em] uppercase text-gold mb-2">Your Photographer</p>
        <h2 class="font-serif font-light text-xl text-ink mb-4">Hey, I'm Moe.</h2>
        <p class="font-light text-ink-soft text-[0.85rem] leading-[1.8] mb-4">
          I've photographed over 50 Indian and South Asian weddings across Edmonton and Alberta.
          I know when the Baraat is about to turn the corner. I know the Vidaai will be emotional
          before it starts. I know where to stand during an Anand Karaj. That cultural knowledge
          shapes every image I make.
        </p>
        <p class="font-light text-ink-soft text-[0.85rem] leading-[1.8]">
          I handle both photo and video myself — one person who knows your family, understands your
          timeline, and captures everything with a consistent style from the first Mehndi night
          through the last reception dance.
        </p>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="mb-14">
    <h2 class="font-serif font-light text-xl text-ink mb-6 text-center">Every package includes</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z', label: 'Professional Editing' },
        { icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10', label: 'Full Download Rights' },
        { icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', label: 'Engagement Session' },
        { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', label: 'Multi-Venue Support' },
      ].map(item => (
        <div class="text-center p-4 rounded-xl bg-[#f7f5f2]">
          <svg class="w-5 h-5 mx-auto mb-2 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d={item.icon}/></svg>
          <p class="text-[0.65rem] font-medium text-ink">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="text-center py-12 border-t border-[#e0dcd6]">
    <h2 class="font-serif font-light text-xl text-ink mb-3">Looking for single-day coverage?</h2>
    <p class="font-light text-ink-soft text-[0.85rem] mb-6 max-w-md mx-auto">
      For single-day weddings, check out our standard packages.
    </p>
    <a href="/wedding-packages/" class="inline-flex items-center gap-2 text-[0.8rem] font-medium text-white bg-ink px-7 py-3 rounded-full hover:bg-[#333] transition-all duration-300">
      View Wedding Packages
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .pkg-card { transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94), box-shadow 0.4s ease; }
  .pkg-card:hover { transform: translateY(-4px); }

  .cat-header {
    background: rgba(255,255,255,0.45);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.6);
    box-shadow: 0 4px 24px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.8);
  }

  @supports not (backdrop-filter: blur(16px)) {
    .cat-header {
      background: #f5f2ed;
    }
  }

  .card-header-glow {
    background-size: 300% 300%;
    animation: headerBreathe 8s ease-in-out infinite;
    background-image: linear-gradient(
      135deg,
      #f9f7f4 0%,
      #f5f0e8 25%,
      #faf6ef 50%,
      #f0ebe1 75%,
      #f9f7f4 100%
    );
  }
  @keyframes headerBreathe {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
</style>
