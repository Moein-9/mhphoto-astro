---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const faqs = [
  { q: 'How much does a wedding photographer cost in Edmonton?', a: 'Wedding photography in Edmonton typically ranges from $1,500 to $5,000+ depending on coverage, experience, and deliverables. At MH Photography, single-day wedding photography starts at $2,250 with full-day coverage, professional editing, and an online gallery with download rights.' },
  { q: 'What is the cheapest way to get good wedding photos?', a: 'The best value comes from booking photo and video together from one team — you save compared to hiring separately, and you get a cohesive look across both. Weekday and off-season weddings (November through March) can also offer flexibility on pricing.' },
  { q: 'What is included in your wedding photography packages?', a: 'Every package includes full-day coverage from getting ready through the reception, professional editing and colour grading, an online gallery with full download rights, and quick turnaround. Reach out for full package details.' },
  { q: 'Do you offer payment plans?', a: 'Yes — I offer flexible payment plans to make booking easier. A deposit secures your date, and the balance can be split into instalments leading up to your wedding day. Reach out and we can figure out what works best for you.' },
  { q: 'Are there hidden fees I should watch out for?', a: 'Not with me. My quotes are straightforward — the price I quote is the price you pay. No surprise editing fees, no per-image charges, no travel surcharges within the Edmonton area. What you see is what you get.' },
  { q: 'Is it worth getting a wedding videographer too?', a: 'If your budget allows, absolutely. Photos capture moments but video captures the sounds, the vows, the laughter. Booking photo + video together from one team is the most cost-effective way to get both.' },
  { q: 'How far in advance should I book to get the best rate?', a: 'I recommend booking 6-12 months in advance, especially for summer and fall dates. Early booking means more flexibility on package customization. Popular weekends fill up fast.' },
  { q: 'Do you photograph small or intimate weddings?', a: 'Absolutely — I love intimate weddings. Whether it is 10 guests or 200, the coverage and care is the same. Elopement and micro-wedding packages are also available.' },
];

const galleryImages = [
  { src: '/gallery-images/weddings/002-first-look.jpg', alt: 'First look — affordable wedding photography Edmonton by MH Photography' },
  { src: '/gallery-images/indian-weddings/002-indian-wedding-couple-veil-edmonton.jpg', alt: 'Indian wedding couple — budget-friendly wedding photographer Edmonton' },
  { src: '/gallery-images/weddings/008-ceremony-kiss.jpg', alt: 'Ceremony kiss — wedding photography packages Edmonton' },
  { src: '/gallery-images/weddings/010-aisle-walk.jpg', alt: 'Walking down the aisle — affordable Edmonton wedding photos' },
  { src: '/gallery-images/engagement/019-engagement-session-cherry-blossom-edmonton.jpg', alt: 'Cherry blossom session — engagement photography Edmonton' },
  { src: '/gallery-images/weddings/003-bride-getting-ready.jpg', alt: 'Bride getting ready — full-day wedding coverage Edmonton' },
  { src: '/gallery-images/indian-weddings/003-indian-wedding-ceremony-moment-edmonton.jpg', alt: 'Ceremony moment — value wedding photography Edmonton' },
  { src: '/gallery-images/weddings/009-ceremony-moment.jpg', alt: 'Emotional moment — documentary wedding photographer Edmonton' },
  { src: '/gallery-images/weddings/006-bride-portrait.jpg', alt: 'Bridal portrait — professional wedding photographer Edmonton' },
];
---

<BaseLayout
  title="Affordable Wedding Photographer Edmonton | Quality Without Compromise"
  description="Edmonton wedding photography from $2,250. Full-day coverage, professional editing, online gallery. Photo + video bundles available. No hidden fees."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Affordable Wedding Photography Edmonton",
      "description": "Professional wedding photography in Edmonton starting at $2,250. Full-day coverage, professional editing, online gallery with download rights. Photo + video packages available.",
      "url": "https://mhphoto.ca/affordable-wedding-photographer-edmonton/",
      "serviceType": "Wedding Photography",
      "provider": {
        "@type": "LocalBusiness",
        "name": "MH Photography",
        "url": "https://mhphoto.ca",
        "email": "moein@mhphoto.ca",
        "founder": { "@type": "Person", "name": "Moein Habibi" },
        "address": { "@type": "PostalAddress", "addressLocality": "Edmonton", "addressRegion": "AB", "addressCountry": "CA" }
      },
      "areaServed": [
        { "@type": "City", "name": "Edmonton" },
        { "@type": "City", "name": "Sherwood Park" },
        { "@type": "City", "name": "St. Albert" },
        { "@type": "City", "name": "Spruce Grove" },
        { "@type": "AdministrativeArea", "name": "Alberta" }
      ],
      "offers": {
        "@type": "Offer",
        "priceCurrency": "CAD",
        "price": "2250",
        "description": "Single-day wedding photography starting price",
        "url": "https://mhphoto.ca/affordable-wedding-photographer-edmonton/"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mhphoto.ca/" },
        { "@type": "ListItem", "position": 2, "name": "Photography", "item": "https://mhphoto.ca/photography/" },
        { "@type": "ListItem", "position": 3, "name": "Affordable Wedding Photography", "item": "https://mhphoto.ca/affordable-wedding-photographer-edmonton/" }
      ]
    })} />
  </Fragment>

  <!-- Breadcrumb -->
  <p class="text-sm font-light mb-1">
    <a href="/photography/" class="text-ink-muted hover:text-gold transition-colors">Photography</a>
    <span class="mx-1.5 text-ink-muted/40">/</span>
    <strong class="font-medium text-ink">Affordable Weddings</strong>
  </p>

  <!-- ============================================= -->
  <!-- HERO -->
  <!-- ============================================= -->
  <section class="mb-16 md:mb-20 reveal">
    <div class="max-w-2xl">
      <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">{site.booking}</p>
      <h1 class="font-serif font-light text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.08] tracking-[-0.02em] text-ink mb-5">
        Affordable Wedding Photographer in Edmonton
      </h1>
      <p class="font-light text-ink-soft text-[0.95rem] leading-[1.75]">
        Beautiful wedding photos shouldn't break the bank. Full-day coverage, professional editing, and an online gallery with download rights — starting at $2,250. No hidden fees, no per-image charges. Just honest pricing and photos you'll love.
      </p>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- VALUE PROPOSITION -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-10 lg:gap-14 items-center">
      <div>
        <div class="w-8 h-px bg-gold/40 mb-6"></div>
        <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.1] text-ink mb-5">
          Quality you can see. Pricing you can afford.
        </h2>
        <div class="space-y-4 font-light text-ink-soft text-[0.9rem] leading-[1.8]">
          <p>
            I know wedding budgets are tight. You're juggling the venue, the food, the flowers, the outfits — and photography is one more line item on a very long list. But here's the thing: <strong class="font-medium text-ink">your photos are the only thing that lasts</strong> after the day is over.
          </p>
          <p>
            That's why I keep my pricing transparent and my packages simple. No surprise fees at the end. No charging per image. No bare-minimum coverage that leaves you scrambling.
            You get a photographer who's been doing this for years, who knows how to find the light
            and capture the moments that matter — at a price that respects your budget.
          </p>
          <div class="bg-gold/[0.06] border-l-2 border-gold/30 rounded-r-xl px-5 py-4">
            <p>
              Affordable doesn't mean less. It means I've built a business around doing great work
              at fair prices — because I'd rather photograph 50 weddings a year that I'm proud of
              than price myself out of the celebrations that actually need me.
            </p>
          </div>
        </div>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="/gallery-images/weddings/002-first-look.jpg"
          alt="First look moment — affordable wedding photographer Edmonton"
          class="w-full h-auto object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- WHAT YOU GET -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-8">
      What every Edmonton wedding package includes
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { title: 'Full-Day Coverage', desc: 'Getting ready through the last dance. No clock-watching, no rushing out early.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
        { title: 'Professional Editing', desc: 'Every image is colour graded and edited. Not just filtered — properly finished.', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
        { title: 'Online Gallery', desc: 'All your photos in a beautiful gallery. Full-resolution downloads included — no watermarks.', icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10' },
        { title: 'No Hidden Fees', desc: 'The price I quote is the price you pay. No editing surcharges, no per-image costs, no surprises.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
      ].map((item) => (
        <div class="bg-cream-warm rounded-xl p-6 border border-ink/[0.04]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A86C" stroke-width="1.5" class="mb-4"><path d={item.icon} /></svg>
          <h3 class="font-serif font-normal text-base text-ink mb-2">{item.title}</h3>
          <p class="font-light text-ink-soft text-[0.8rem] leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================= -->
  <!-- PRICING PREVIEW -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">Starting Prices</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-8">
      Transparent pricing — no surprises
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-2xl mx-auto">
      <!-- Photography -->
      <div class="rounded-2xl ring-1 ring-ink/[0.08] overflow-hidden bg-white shadow-sm">
        <div class="relative h-[180px] overflow-hidden">
          <img src="/images/categories/weddings.jpg" alt="Wedding photography packages Edmonton" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
        <div class="p-5">
          <h3 class="font-serif font-light text-lg text-gold-warm text-center tracking-wide uppercase mb-0.5">Photography</h3>
          <p class="text-[0.7rem] text-ink-muted text-center font-light mb-3">Wedding Packages</p>
          <div class="space-y-2 mb-4">
            <div class="flex items-center gap-3 bg-[#f7f5f2] rounded-xl px-3 py-2.5">
              <div>
                <p class="text-[0.65rem] text-ink-muted font-light">Single-day starts at</p>
                <p class="text-lg font-serif font-light text-ink">$2,250</p>
              </div>
            </div>
            <div class="flex items-center gap-3 bg-[#f7f5f2] rounded-xl px-3 py-2.5">
              <div>
                <p class="text-[0.65rem] text-ink-muted font-light">Multi-day starts at</p>
                <p class="text-lg font-serif font-light text-ink">$6,490</p>
              </div>
            </div>
          </div>
          <a href="/contact/" class="block text-center font-semibold text-[0.65rem] tracking-[0.12em] uppercase text-ink border border-ink/20 py-2.5 rounded-full hover:bg-ink hover:text-white transition-all duration-300">
            Let's Talk
          </a>
        </div>
      </div>

      <!-- Photo + Video -->
      <div class="rounded-2xl ring-2 ring-gold/30 overflow-hidden bg-white shadow-lg">
        <div class="relative h-[180px] overflow-hidden">
          <img src="/images/categories/photo-video.jpg" alt="Photo and video wedding packages Edmonton" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          <span class="absolute top-3 right-3 text-[0.55rem] font-semibold tracking-[0.12em] uppercase text-white bg-gold/90 backdrop-blur-sm px-3 py-1 rounded-full">Best Value</span>
        </div>
        <div class="p-5">
          <h3 class="font-serif font-light text-lg text-gold-warm text-center tracking-wide uppercase mb-0.5">Photo + Video</h3>
          <p class="text-[0.7rem] text-ink-muted text-center font-light mb-3">Wedding Packages</p>
          <div class="space-y-2 mb-4">
            <div class="flex items-center gap-3 bg-[#f7f5f2] rounded-xl px-3 py-2.5">
              <div>
                <p class="text-[0.65rem] text-ink-muted font-light">Single-day starts at</p>
                <p class="text-lg font-serif font-light text-ink">$8,750</p>
              </div>
            </div>
            <div class="flex items-center gap-3 bg-[#f7f5f2] rounded-xl px-3 py-2.5">
              <div>
                <p class="text-[0.65rem] text-ink-muted font-light">Multi-day starts at</p>
                <p class="text-lg font-serif font-light text-ink">$17,990</p>
              </div>
            </div>
          </div>
          <a href="/contact/" class="block text-center font-semibold text-[0.65rem] tracking-[0.12em] uppercase bg-ink text-white py-2.5 rounded-full hover:bg-[#333] transition-colors duration-300">
            Let's Talk
          </a>
        </div>
      </div>
    </div>
    <p class="text-center text-[0.75rem] font-light text-ink-muted mt-6">
      Every celebration is unique — <a href="/contact/" class="text-gold hover:text-gold-deep transition-colors">reach out</a> for a custom quote. Payment plans available.
    </p>
    <p class="text-center mt-4">
      <a href="/pricing/" class="font-light text-sm text-ink border-b border-ink/30 pb-0.5 hover:border-ink transition-colors duration-300">
        View all packages &rarr;
      </a>
    </p>
  </section>

  <!-- ============================================= -->
  <!-- GALLERY -->
  <!-- ============================================= -->
  <section class="mb-20 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <p class="text-[0.65rem] font-medium tracking-[0.2em] uppercase text-gold mb-3">Portfolio</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-6">
      Real Edmonton weddings
    </h2>
    <div class="columns-2 md:columns-3 gap-3 space-y-3">
      {galleryImages.map((img) => (
        <div class="break-inside-avoid rounded-lg overflow-hidden">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-auto object-cover hover:scale-[1.02] transition-transform duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>
    <div class="flex items-center justify-center gap-6 mt-8">
      <a href="/photography/weddings/" class="font-light text-sm text-ink border-b border-ink/30 pb-0.5 hover:border-ink transition-colors duration-300">
        Full wedding gallery &rarr;
      </a>
      <a href="/photography/indian-weddings/" class="font-light text-sm text-ink border-b border-ink/30 pb-0.5 hover:border-ink transition-colors duration-300">
        Indian wedding gallery &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================= -->
  <!-- CTA -->
  <!-- ============================================= -->
  <section class="text-center py-16 mb-10 reveal">
    <p class="text-[0.65rem] font-medium tracking-[0.18em] uppercase text-gold mb-3">{site.booking}</p>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2.25rem)] text-ink mb-4">
      Let's make it happen.
    </h2>
    <p class="font-light text-ink-muted text-sm mb-7 max-w-md mx-auto">
      Tell me about your day — date, venue, vibe — and I'll put together a package that works for you. No pressure, no sales pitch.
    </p>
    <a href="/contact/" class="inline-block font-medium text-[0.7rem] tracking-[0.12em] uppercase text-white bg-ink px-10 py-4 rounded-full hover:bg-[#333] transition-colors duration-300">
      Get in Touch
    </a>
  </section>

  <!-- ============================================= -->
  <!-- FAQ -->
  <!-- ============================================= -->
  <section class="max-w-2xl mx-auto mb-16 reveal">
    <div class="w-8 h-px bg-gold/40 mb-8"></div>
    <h2 class="font-serif font-light text-[clamp(1.5rem,3vw,2rem)] text-ink mb-8">
      Wedding Photography Pricing — FAQ
    </h2>
    {faqs.map((faq) => (
      <div class="faq-item border-b border-ink/[0.06] first:border-t">
        <button class="flex justify-between items-center w-full py-5 text-left cursor-pointer group" onclick="this.closest('.faq-item').classList.toggle('open')">
          <h3 class="font-normal text-[0.9rem] text-ink pr-4 leading-relaxed group-hover:text-gold-deep transition-colors">{faq.q}</h3>
          <svg class="faq-chevron w-4 h-4 text-ink-muted flex-shrink-0 transition-transform duration-500" style="transition-timing-function:cubic-bezier(0.16,1,0.3,1)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-answer"><p class="font-light text-[0.85rem] text-ink-soft leading-[1.7] pb-5 max-w-[640px]">{faq.a}</p></div>
      </div>
    ))}
  </section>

  <!-- ============================================= -->
  <!-- CROSS-LINKS -->
  <!-- ============================================= -->
  <section class="py-10 border-t border-[#e0dcd6]">
    <h2 class="font-serif font-light text-xl text-ink mb-5">Explore more</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href="/photography/weddings/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">Wedding Gallery</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">See the portfolio</p>
      </a>
      <a href="/wedding-photo-video-packages-edmonton/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">Photo + Video</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">Combined packages</p>
      </a>
      <a href="/elopement-photographer-edmonton/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">Elopements</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">Intimate weddings</p>
      </a>
      <a href="/pricing/" class="text-center p-4 rounded-xl bg-[#f7f5f2] hover:bg-gold/10 transition-colors">
        <p class="text-[0.75rem] font-medium text-ink">All Packages</p>
        <p class="text-[0.65rem] font-light text-ink-muted mt-1">View pricing</p>
      </a>
    </div>
  </section>
</BaseLayout>
