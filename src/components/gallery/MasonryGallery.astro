---
/**
 * Tetris-style masonry gallery — images packed tight like puzzle pieces.
 * Clean rounded corners, tiny gaps, no decorative frames.
 * Click to open cream lightbox with swipe support.
 */
interface Props {
  slug: string;
  altPrefix: string;
}

import fs from 'node:fs';
import path from 'node:path';

const { slug, altPrefix } = Astro.props;

const galleryDir = path.join(process.cwd(), 'public/gallery-images', slug);
let images: { src: string; alt: string }[] = [];
try {
  const files = fs.readdirSync(galleryDir)
    .filter((f: string) => /\.(jpg|jpeg|png|webp)$/i.test(f))
    .sort();
  // SEO-friendly alt text variations per category
  const altVariations: Record<string, string[]> = {
    'weddings': [
      'wedding ceremony moment', 'bride and groom portrait', 'wedding reception details',
      'first dance', 'wedding party celebration', 'bridal portrait', 'couple portrait',
      'wedding venue decor', 'romantic wedding moment', 'candid wedding photography',
      'wedding toast', 'getting ready', 'groom portrait', 'wedding rings detail',
      'bouquet toss', 'ceremony exchange', 'sunset couple portrait', 'wedding cake',
    ],
    'indian-weddings': [
      'mehndi ceremony', 'baraat procession', 'Indian wedding ceremony', 'haldi celebration',
      'sangeet night dance', 'bridal portrait', 'mandap ceremony', 'wedding couple portrait',
      'reception celebration', 'traditional rituals', 'ceremony details', 'bridal jewelry',
      'Indian wedding decor', 'vidaai moment', 'wedding guests celebration', 'pheras ceremony',
      'Indian wedding couple', 'dupatta draping moment',
    ],
    'family': [
      'family portrait session', 'candid family moment', 'kids playing outdoors',
      'family walking together', 'sibling portrait', 'parents with children', 'fall family session',
      'river valley family photos', 'family laughing together', 'outdoor family portrait',
      'children portrait', 'family in nature', 'autumn family photography', 'family group photo',
      'toddler portrait', 'family lifestyle moment',
    ],
    'engagement': [
      'engagement couple portrait', 'romantic engagement session', 'couple walking together',
      'ring detail shot', 'engagement pose', 'couple at sunset', 'urban engagement photos',
      'candid couple moment', 'engagement session Edmonton', 'couple portrait outdoors',
      'engagement celebration', 'proposal photography',
    ],
  };

  // Detect non-descriptive filenames (camera codes, numbers-only, generic prefixes)
  const isNonDescriptive = (name: string) =>
    /^(pictures?|picture|dsc|img|sj|frame|ss|untitled|screen shot|fall session|fotorcreated)\b/i.test(name) ||
    /^\d+(\s\d+)*$/.test(name) ||
    name.length < 3;

  const variations = altVariations[slug] || ['photography by MH Photography'];
  let variationIndex = 0;

  images = files.map((f: string) => {
    const rawName = f.replace(/^\d+[a-z]?-/, '').replace(/\.[^.]+$/, '').replace(/[_-]/g, ' ').replace(/\(.*?\)/g, '').trim();
    let altSuffix: string;
    if (isNonDescriptive(rawName)) {
      altSuffix = variations[variationIndex % variations.length];
      variationIndex++;
    } else {
      altSuffix = rawName;
    }
    return {
      src: `/gallery-images/${slug}/${f}`,
      alt: `${altPrefix} — ${altSuffix}`,
    };
  });
} catch (e) { /* empty */ }
---

{images.length > 0 && (
  <!-- Skeleton wireframe shown while images load -->
  <div class="gallery-skeleton" id={`skel-${slug}`}>
    {[180,240,160,220,200,180,250,170,210,190,230,160].map(h => (
      <div class="skel-item" style={`height:${h}px`}></div>
    ))}
  </div>

  <div class="tetris-gallery" id={`gallery-${slug}`}>
    {images.map((img, i) => (
      <div class="tetris-item" data-lightbox={i}>
        <img src={img.src} alt={img.alt} loading={i < 6 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} />
      </div>
    ))}
  </div>

  <!-- Cream Lightbox -->
  <div id={`lb-${slug}`} class="lb-wrap">
    <div class="lb-backdrop"></div>
    <button class="lb-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <button class="lb-prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="lb-next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="lb-card">
      <img class="lb-img" src="" alt="" />
      <p class="lb-counter"></p>
    </div>
  </div>

  <style>
    /* ===== TETRIS MASONRY — CSS columns, tight packing ===== */
    .tetris-gallery {
      columns: 2;
      column-gap: 4px;
    }
    @media (min-width: 640px) {
      .tetris-gallery { columns: 3; column-gap: 5px; }
    }
    @media (min-width: 1024px) {
      .tetris-gallery { columns: 3; column-gap: 6px; }
    }

    /* Gallery hidden until all images loaded */
    .tetris-gallery {
      opacity: 0;
    }
    .tetris-gallery.settled {
      opacity: 1;
    }

    /* Skeleton overlay — shown while gallery loads */
    .gallery-skeleton {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }
    @media (min-width: 640px) {
      .gallery-skeleton { grid-template-columns: repeat(3, 1fr); gap: 5px; }
    }
    .gallery-skeleton.hidden { display: none; }
    .skel-item {
      border-radius: 6px;
      background: linear-gradient(90deg, #eae5df 25%, #f3ede7 50%, #eae5df 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
    @media (min-width: 640px) {
      .skel-item { border-radius: 8px; }
    }
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .tetris-item {
      break-inside: avoid;
      margin-bottom: 4px;
      border-radius: 6px;
      overflow: hidden;
      cursor: pointer;
      transition: opacity 0.3s;
    }
    @media (min-width: 640px) {
      .tetris-item { margin-bottom: 5px; border-radius: 8px; }
    }
    .tetris-item:hover { opacity: 0.92; }
    .tetris-item img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* ===== iOS-STYLE LIGHTBOX ===== */
    .lb-wrap {
      position: fixed;
      inset: 0;
      z-index: 100000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s;
    }
    .lb-wrap.open {
      opacity: 1;
      visibility: visible;
    }
    .lb-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.92);
      -webkit-backdrop-filter: blur(30px);
      backdrop-filter: blur(30px);
    }
    .lb-card {
      position: relative;
      z-index: 2;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      touch-action: pan-y;
      overflow: hidden;
    }
    .lb-img {
      max-width: 92vw;
      max-height: 85vh;
      object-fit: contain;
      border-radius: 4px;
      will-change: transform, opacity;
      transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease;
      user-select: none;
      -webkit-user-drag: none;
    }
    .lb-img.swiping {
      transition: none;
    }
    .lb-img.slide-left {
      transform: translateX(-100vw);
      opacity: 0;
    }
    .lb-img.slide-right {
      transform: translateX(100vw);
      opacity: 0;
    }
    .lb-counter {
      position: absolute;
      bottom: max(20px, env(safe-area-inset-bottom, 20px));
      left: 50%;
      transform: translateX(-50%);
      font-size: 12px;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.5);
      font-weight: 400;
      z-index: 10;
    }
    .lb-close {
      position: absolute;
      top: max(16px, env(safe-area-inset-top, 16px));
      right: 16px;
      z-index: 10;
      color: #fff;
      background: rgba(255,255,255,0.15);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      border: none;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }
    .lb-close:hover { background: rgba(255,255,255,0.25); }
    .lb-prev, .lb-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      color: #fff;
      background: rgba(255,255,255,0.12);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      border: none;
      cursor: pointer;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, opacity 0.2s;
    }
    .lb-prev { left: 12px; }
    .lb-next { right: 12px; }
    .lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.25); }

    @media (max-width: 640px) {
      .lb-prev, .lb-next { display: none; }
      .lb-close {
        width: 32px; height: 32px; top: 12px; right: 12px;
        /* Remove backdrop-filter on mobile — stacked blur layers crash older devices */
        -webkit-backdrop-filter: none;
        backdrop-filter: none;
        background: rgba(255,255,255,0.25);
      }
      .lb-backdrop {
        /* Reduce blur on mobile to prevent GPU memory exhaustion */
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
      }
      .lb-img { max-width: 100vw; max-height: 90vh; border-radius: 0; }
    }
  </style>

  <!-- Skeleton stays until above-fold images are loaded AND layout is stable -->
  <script define:vars={{ gallerySlug: slug }}>
    (function() {
      var gallery = document.getElementById('gallery-' + gallerySlug);
      var skeleton = document.getElementById('skel-' + gallerySlug);
      if (!gallery || !skeleton) return;

      var imgs = Array.from(gallery.querySelectorAll('img'));
      var settled = false;

      function settle() {
        if (settled) return;
        settled = true;
        // Wait one extra frame for the browser to finish column layout reflow
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            skeleton.classList.add('hidden');
            gallery.classList.add('settled');
          });
        });
      }

      // Only wait for the first batch of images (above the fold).
      // Loading ALL images eagerly on mobile causes memory exhaustion
      // and crashes — especially on galleries with 60-100+ images.
      // The first 6 are already set to loading="eager" in the HTML.
      var aboveFoldCount = Math.min(6, imgs.length);
      var loaded = 0;

      function check() {
        loaded++;
        if (loaded >= aboveFoldCount) settle();
      }

      // Only force-load the first batch; leave the rest as lazy
      imgs.forEach(function(img, i) {
        if (i < aboveFoldCount) {
          // These are already eager, just track their load
          if (img.complete && img.naturalHeight > 0) { check(); return; }
          img.addEventListener('load', check, { once: true });
          img.addEventListener('error', check, { once: true });
        }
        // Leave remaining images with loading="lazy" — do NOT strip it
      });

      // Fallback — show after 4s max (reduced from 5s for better UX)
      setTimeout(settle, 4000);
    })();
  </script>

  <script define:vars={{ slug, totalImages: images.length, imageSrcs: images.map(img => img.src), imageAlts: images.map(img => img.alt) }}>
    (function() {
      var lb = document.getElementById('lb-' + slug);
      if (!lb) return;
      var lbImg = lb.querySelector('.lb-img');
      var lbCounter = lb.querySelector('.lb-counter');
      if (!lbImg || !lbCounter) return;

      var idx = 0;
      var navInProgress = false;

      // Unified touch state — single set of handlers, no duplicates
      var touchState = {
        startX: 0,
        startY: 0,
        currentX: 0,
        currentY: 0,
        isDragging: false,
        directionLocked: false,  // once we decide horizontal vs vertical, lock it
        isHorizontal: false,
        isVertical: false,
        isDragClose: false
      };

      function showImage(i) {
        idx = i;
        lbImg.src = imageSrcs[idx];
        lbImg.alt = imageAlts[idx] || '';
        lbCounter.textContent = (idx + 1) + ' / ' + totalImages;
      }

      function openLB(i) {
        showImage(i);
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeLB() {
        lb.classList.remove('open');
        document.body.style.overflow = '';
        lbImg.style.transform = '';
        lbImg.style.opacity = '';
        lbImg.classList.remove('swiping');
        lb.style.opacity = '';
        navInProgress = false;
        // Reset touch state
        touchState.isDragging = false;
        touchState.directionLocked = false;
        touchState.isDragClose = false;
      }

      function navLB(dir) {
        if (navInProgress) return;
        var newIdx = idx + dir;
        if (newIdx < 0 || newIdx >= totalImages) {
          // Bounce back — rubber band effect
          lbImg.classList.remove('swiping');
          lbImg.style.transform = '';
          lbImg.style.opacity = '';
          return;
        }

        navInProgress = true;

        // Slide out
        lbImg.classList.remove('swiping');
        lbImg.classList.add(dir > 0 ? 'slide-left' : 'slide-right');

        setTimeout(function() {
          // Load new image while offscreen
          showImage(newIdx);
          // Position on opposite side
          lbImg.classList.remove('slide-left', 'slide-right');
          lbImg.classList.add('swiping');
          lbImg.style.transform = 'translateX(' + (dir > 0 ? '80vw' : '-80vw') + ')';
          lbImg.style.opacity = '0';

          // Slide in
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              lbImg.classList.remove('swiping');
              lbImg.style.transform = '';
              lbImg.style.opacity = '';
              navInProgress = false;
            });
          });
        }, 200);
      }

      // Open on click
      var galleryItems = document.querySelectorAll('#gallery-' + slug + ' [data-lightbox]');
      galleryItems.forEach(function(el) {
        el.addEventListener('click', function() {
          var i = parseInt(el.dataset.lightbox);
          if (!isNaN(i)) openLB(i);
        });
      });

      // Close
      var closeBtn = lb.querySelector('.lb-close');
      var backdrop = lb.querySelector('.lb-backdrop');
      if (closeBtn) closeBtn.addEventListener('click', closeLB);
      if (backdrop) backdrop.addEventListener('click', closeLB);

      // Nav buttons (desktop)
      var prevBtn = lb.querySelector('.lb-prev');
      var nextBtn = lb.querySelector('.lb-next');
      if (prevBtn) prevBtn.addEventListener('click', function(e) { e.stopPropagation(); navLB(-1); });
      if (nextBtn) nextBtn.addEventListener('click', function(e) { e.stopPropagation(); navLB(1); });

      // Keyboard
      document.addEventListener('keydown', function(e) {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') closeLB();
        if (e.key === 'ArrowRight') navLB(1);
        if (e.key === 'ArrowLeft') navLB(-1);
      });

      // UNIFIED touch handling — single set of handlers for both
      // horizontal swipe navigation AND vertical swipe-down-to-close.
      // The old code had TWO separate touchstart/touchmove/touchend
      // registrations on the same element, causing conflicts and
      // race conditions that could crash mobile browsers.
      var card = lb.querySelector('.lb-card');
      if (!card) return;

      card.addEventListener('touchstart', function(e) {
        if (!e.touches || !e.touches[0]) return;
        touchState.startX = e.touches[0].clientX;
        touchState.startY = e.touches[0].clientY;
        touchState.currentX = 0;
        touchState.currentY = 0;
        touchState.isDragging = true;
        touchState.directionLocked = false;
        touchState.isHorizontal = false;
        touchState.isVertical = false;
        touchState.isDragClose = false;
        lbImg.classList.add('swiping');
      }, { passive: true });

      card.addEventListener('touchmove', function(e) {
        if (!touchState.isDragging || !e.touches || !e.touches[0]) return;
        var dx = e.touches[0].clientX - touchState.startX;
        var dy = e.touches[0].clientY - touchState.startY;
        touchState.currentX = dx;
        touchState.currentY = dy;

        // Lock direction on first significant move (10px threshold)
        if (!touchState.directionLocked && (Math.abs(dx) > 10 || Math.abs(dy) > 10)) {
          touchState.directionLocked = true;
          if (Math.abs(dy) > Math.abs(dx)) {
            touchState.isVertical = true;
          } else {
            touchState.isHorizontal = true;
          }
        }

        if (!touchState.directionLocked) return;

        // HORIZONTAL swipe — navigate between images
        if (touchState.isHorizontal) {
          e.preventDefault();
          var atEdge = (idx === 0 && dx > 0) || (idx === totalImages - 1 && dx < 0);
          var resistance = atEdge ? 0.3 : 1;
          var translate = dx * resistance;
          var winWidth = window.innerWidth || 1;
          var opacity = 1 - Math.abs(translate) / winWidth * 0.5;

          lbImg.style.transform = 'translateX(' + translate + 'px)';
          lbImg.style.opacity = String(Math.max(0.4, opacity));
        }

        // VERTICAL swipe down — close lightbox
        if (touchState.isVertical && dy > 30 && Math.abs(dx) < 30) {
          touchState.isDragClose = true;
          var closeOpacity = 1 - dy / 400;
          lb.style.opacity = String(Math.max(0.3, closeOpacity));
          var scale = Math.max(0.85, 1 - dy / 1000);
          lbImg.style.transform = 'translateY(' + (dy * 0.5) + 'px) scale(' + scale + ')';
        }
      }, { passive: false });

      card.addEventListener('touchend', function() {
        if (!touchState.isDragging) return;
        touchState.isDragging = false;
        lbImg.classList.remove('swiping');

        // Handle vertical close
        if (touchState.isDragClose && touchState.currentY > 120) {
          closeLB();
          return;
        }

        // Handle horizontal swipe
        if (touchState.isHorizontal) {
          var threshold = (window.innerWidth || 320) * 0.2;
          if (touchState.currentX < -threshold && idx < totalImages - 1) {
            navLB(1);
          } else if (touchState.currentX > threshold && idx > 0) {
            navLB(-1);
          } else {
            // Snap back
            lbImg.style.transform = '';
            lbImg.style.opacity = '';
          }
          return;
        }

        // Reset everything if no action taken
        lb.style.opacity = '';
        lbImg.style.transform = '';
        lbImg.style.opacity = '';
        touchState.isDragClose = false;
      }, { passive: true });
    })();
  </script>
)}
