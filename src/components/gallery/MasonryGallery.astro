---
/**
 * Tetris-style masonry gallery — images packed tight like puzzle pieces.
 * Clean rounded corners, tiny gaps, no decorative frames.
 * Click to open cream lightbox with swipe support.
 */
interface Props {
  slug: string;
  altPrefix: string;
}

import fs from 'node:fs';
import path from 'node:path';

const { slug, altPrefix } = Astro.props;

const galleryDir = path.join(process.cwd(), 'public/gallery-images', slug);
let images: { src: string; alt: string }[] = [];
try {
  const files = fs.readdirSync(galleryDir)
    .filter((f: string) => /\.(jpg|jpeg|png|webp)$/i.test(f))
    .sort();
  images = files.map((f: string) => {
    const name = f.replace(/^\d+-/, '').replace(/\.[^.]+$/, '').replace(/[_-]/g, ' ').replace(/\(.*?\)/g, '').trim();
    return {
      src: `/gallery-images/${slug}/${f}`,
      alt: `${altPrefix} — ${name || 'Edmonton photography by MH Photography'}`,
    };
  });
} catch (e) { /* empty */ }
---

{images.length > 0 && (
  <!-- Skeleton wireframe shown while images load -->
  <div class="gallery-skeleton" id={`skel-${slug}`}>
    {[180,240,160,220,200,180,250,170,210,190,230,160].map(h => (
      <div class="skel-item" style={`height:${h}px`}></div>
    ))}
  </div>

  <div class="tetris-gallery" id={`gallery-${slug}`}>
    {images.map((img, i) => (
      <div class="tetris-item" data-lightbox={i}>
        <img src={img.src} alt={img.alt} loading={i < 6 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : undefined} />
      </div>
    ))}
  </div>

  <!-- Cream Lightbox -->
  <div id={`lb-${slug}`} class="lb-wrap">
    <div class="lb-backdrop"></div>
    <button class="lb-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <button class="lb-prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="lb-next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="lb-card">
      <img class="lb-img" src="" alt="" />
      <p class="lb-counter"></p>
    </div>
  </div>

  <style>
    /* ===== TETRIS MASONRY — CSS columns, tight packing ===== */
    .tetris-gallery {
      columns: 2;
      column-gap: 4px;
    }
    @media (min-width: 640px) {
      .tetris-gallery { columns: 3; column-gap: 5px; }
    }
    @media (min-width: 1024px) {
      .tetris-gallery { columns: 3; column-gap: 6px; }
    }

    /* Gallery hidden until all images loaded */
    .tetris-gallery {
      opacity: 0;
    }
    .tetris-gallery.settled {
      opacity: 1;
    }

    /* Skeleton overlay — shown while gallery loads */
    .gallery-skeleton {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }
    @media (min-width: 640px) {
      .gallery-skeleton { grid-template-columns: repeat(3, 1fr); gap: 5px; }
    }
    .gallery-skeleton.hidden { display: none; }
    .skel-item {
      border-radius: 6px;
      background: linear-gradient(90deg, #eae5df 25%, #f3ede7 50%, #eae5df 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
    @media (min-width: 640px) {
      .skel-item { border-radius: 8px; }
    }
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .tetris-item {
      break-inside: avoid;
      margin-bottom: 4px;
      border-radius: 6px;
      overflow: hidden;
      cursor: pointer;
      transition: opacity 0.3s;
    }
    @media (min-width: 640px) {
      .tetris-item { margin-bottom: 5px; border-radius: 8px; }
    }
    .tetris-item:hover { opacity: 0.92; }
    .tetris-item img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* ===== iOS-STYLE LIGHTBOX ===== */
    .lb-wrap {
      position: fixed;
      inset: 0;
      z-index: 100000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s;
    }
    .lb-wrap.open {
      opacity: 1;
      visibility: visible;
    }
    .lb-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.92);
      -webkit-backdrop-filter: blur(30px);
      backdrop-filter: blur(30px);
    }
    .lb-card {
      position: relative;
      z-index: 2;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      touch-action: pan-y;
      overflow: hidden;
    }
    .lb-img {
      max-width: 92vw;
      max-height: 85vh;
      object-fit: contain;
      border-radius: 4px;
      will-change: transform, opacity;
      transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.3s ease;
      user-select: none;
      -webkit-user-drag: none;
    }
    .lb-img.swiping {
      transition: none;
    }
    .lb-img.slide-left {
      transform: translateX(-100vw);
      opacity: 0;
    }
    .lb-img.slide-right {
      transform: translateX(100vw);
      opacity: 0;
    }
    .lb-counter {
      position: absolute;
      bottom: max(20px, env(safe-area-inset-bottom, 20px));
      left: 50%;
      transform: translateX(-50%);
      font-size: 12px;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.5);
      font-weight: 400;
      z-index: 10;
    }
    .lb-close {
      position: absolute;
      top: max(16px, env(safe-area-inset-top, 16px));
      right: 16px;
      z-index: 10;
      color: #fff;
      background: rgba(255,255,255,0.15);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      border: none;
      cursor: pointer;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }
    .lb-close:hover { background: rgba(255,255,255,0.25); }
    .lb-prev, .lb-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      color: #fff;
      background: rgba(255,255,255,0.12);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      border: none;
      cursor: pointer;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, opacity 0.2s;
    }
    .lb-prev { left: 12px; }
    .lb-next { right: 12px; }
    .lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,0.25); }

    @media (max-width: 640px) {
      .lb-prev, .lb-next { display: none; }
      .lb-close { width: 32px; height: 32px; top: 12px; right: 12px; }
      .lb-img { max-width: 100vw; max-height: 90vh; border-radius: 0; }
    }
  </style>

  <!-- Skeleton stays until ALL images are loaded AND layout is stable -->
  <script define:vars={{ gallerySlug: slug }}>
    (function() {
      const gallery = document.getElementById('gallery-' + gallerySlug);
      const skeleton = document.getElementById('skel-' + gallerySlug);
      if (!gallery || !skeleton) return;

      const imgs = Array.from(gallery.querySelectorAll('img'));
      let loaded = 0;

      function settle() {
        // Wait one extra frame for the browser to finish column layout reflow
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            skeleton.classList.add('hidden');
            gallery.classList.add('settled');
          });
        });
      }

      function check() {
        loaded++;
        // Wait for ALL images, not just first 12
        if (loaded >= imgs.length) settle();
      }

      // Force all images to load eagerly on mobile (no lazy)
      imgs.forEach(function(img) {
        img.removeAttribute('loading');
        if (img.complete && img.naturalHeight > 0) { check(); return; }
        img.addEventListener('load', check, { once: true });
        img.addEventListener('error', check, { once: true });
      });

      // Fallback — show after 5s max
      setTimeout(settle, 5000);
    })();
  </script>

  <script define:vars={{ slug, totalImages: images.length, imageSrcs: images.map(img => img.src) }}>
    (function() {
      const lb = document.getElementById('lb-' + slug);
      const lbImg = lb.querySelector('.lb-img');
      const lbCounter = lb.querySelector('.lb-counter');
      let idx = 0;
      let startX = 0, startY = 0, currentX = 0, isDragging = false, isVertical = false;

      function showImage(i) {
        idx = i;
        lbImg.src = imageSrcs[idx];
        lbCounter.textContent = (idx + 1) + ' / ' + totalImages;
      }

      function openLB(i) {
        showImage(i);
        lb.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeLB() {
        lb.classList.remove('open');
        document.body.style.overflow = '';
        lbImg.style.transform = '';
        lbImg.style.opacity = '';
        lbImg.classList.remove('swiping');
      }

      function navLB(dir) {
        var newIdx = idx + dir;
        if (newIdx < 0 || newIdx >= totalImages) {
          // Bounce back — rubber band effect
          lbImg.classList.remove('swiping');
          lbImg.style.transform = '';
          lbImg.style.opacity = '';
          return;
        }

        // Slide out
        lbImg.classList.remove('swiping');
        lbImg.classList.add(dir > 0 ? 'slide-left' : 'slide-right');

        setTimeout(function() {
          // Load new image while offscreen
          showImage(newIdx);
          // Position on opposite side
          lbImg.classList.remove('slide-left', 'slide-right');
          lbImg.classList.add('swiping');
          lbImg.style.transform = 'translateX(' + (dir > 0 ? '80vw' : '-80vw') + ')';
          lbImg.style.opacity = '0';

          // Slide in
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              lbImg.classList.remove('swiping');
              lbImg.style.transform = '';
              lbImg.style.opacity = '';
            });
          });
        }, 200);
      }

      // Open on click
      document.querySelectorAll('#gallery-' + slug + ' [data-lightbox]').forEach(function(el) {
        el.addEventListener('click', function() { openLB(parseInt(el.dataset.lightbox)); });
      });

      // Close
      lb.querySelector('.lb-close').addEventListener('click', closeLB);
      lb.querySelector('.lb-backdrop').addEventListener('click', closeLB);

      // Nav buttons (desktop)
      lb.querySelector('.lb-prev').addEventListener('click', function(e) { e.stopPropagation(); navLB(-1); });
      lb.querySelector('.lb-next').addEventListener('click', function(e) { e.stopPropagation(); navLB(1); });

      // Keyboard
      document.addEventListener('keydown', function(e) {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') closeLB();
        if (e.key === 'ArrowRight') navLB(1);
        if (e.key === 'ArrowLeft') navLB(-1);
      });

      // iOS-style touch swipe with live drag feedback
      var card = lb.querySelector('.lb-card');

      card.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        currentX = 0;
        isDragging = true;
        isVertical = false;
        lbImg.classList.add('swiping');
      }, { passive: true });

      card.addEventListener('touchmove', function(e) {
        if (!isDragging) return;
        var dx = e.touches[0].clientX - startX;
        var dy = e.touches[0].clientY - startY;

        // Determine direction on first significant move
        if (!isVertical && Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 10) {
          isVertical = true;
        }
        if (isVertical) return;

        e.preventDefault();
        currentX = dx;

        // Rubber band at edges
        var atEdge = (idx === 0 && dx > 0) || (idx === totalImages - 1 && dx < 0);
        var resistance = atEdge ? 0.3 : 1;
        var translate = dx * resistance;
        var opacity = 1 - Math.abs(translate) / window.innerWidth * 0.5;

        lbImg.style.transform = 'translateX(' + translate + 'px)';
        lbImg.style.opacity = Math.max(0.4, opacity);
      }, { passive: false });

      card.addEventListener('touchend', function() {
        if (!isDragging || isVertical) { isDragging = false; return; }
        isDragging = false;
        lbImg.classList.remove('swiping');

        var threshold = window.innerWidth * 0.2;

        if (currentX < -threshold && idx < totalImages - 1) {
          navLB(1);
        } else if (currentX > threshold && idx > 0) {
          navLB(-1);
        } else {
          // Snap back
          lbImg.style.transform = '';
          lbImg.style.opacity = '';
        }
      }, { passive: true });

      // Swipe down to close (iOS style)
      var startDragY = 0, dragY = 0, isDragClose = false;
      card.addEventListener('touchstart', function(e) {
        startDragY = e.touches[0].clientY;
        dragY = 0;
        isDragClose = false;
      }, { passive: true });

      card.addEventListener('touchmove', function(e) {
        dragY = e.touches[0].clientY - startDragY;
        if (dragY > 30 && Math.abs(currentX) < 10) {
          isDragClose = true;
          var opacity = 1 - dragY / 400;
          lb.style.opacity = Math.max(0.3, opacity);
          lbImg.style.transform = 'translateY(' + dragY * 0.5 + 'px) scale(' + Math.max(0.85, 1 - dragY / 1000) + ')';
        }
      }, { passive: true });

      card.addEventListener('touchend', function() {
        if (isDragClose && dragY > 120) {
          closeLB();
          lb.style.opacity = '';
        } else {
          lb.style.opacity = '';
          lbImg.style.transform = '';
        }
        isDragClose = false;
      }, { passive: true });
    })();
  </script>
)}
