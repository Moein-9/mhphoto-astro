---
import { primaryNav, photographyNav } from '../../data/navigation';
import { site } from '../../data/site';

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- Mobile header bar -->
<header id="mobile-header" class="fixed top-0 left-0 xl:hidden w-full z-[10000] flex items-center justify-between transition-all duration-300 px-6 py-5">
  <a href="/">
    <img src="/logo.png" alt={`${site.name} — Edmonton wedding photographer`} class="w-[68px] h-[52px] object-contain" />
  </a>
  <button id="nav-open" class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<!-- Mobile overlay nav -->
<div id="mobile-nav" class="mobile-overlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div class="mobile-overlay-inner">
    <!-- Top bar -->
    <div class="flex items-center justify-between mb-6">
      <button id="nav-close" class="close-btn" aria-label="Close menu">
        <span class="close-x">&times;</span>
        <span>Close</span>
      </button>
      <a href="/">
        <img src="/logo.png" alt={`${site.name} logo`} class="w-16 h-12 object-contain" />
      </a>
    </div>

    <!-- Nav items -->
    <nav class="flex-1 flex flex-col justify-center" aria-label="Main navigation">
      <ul class="list-none p-0 m-0">
        {primaryNav.map((item, idx) => (
          <li class="menu-item" style={`--i:${idx}`}>
            {item.label === 'Photography' ? (
              <div>
                <button
                  id="photo-toggle"
                  class:list={[
                    'menu-link w-full flex items-center justify-between',
                    isActive(item.href) ? 'text-gold' : '',
                  ]}
                >
                  <span>{item.label}</span>
                  <span class="menu-badge">
                    <span class="badge-text">(+{photographyNav.length})</span>
                    <span class="badge-icon">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>
                    </span>
                  </span>
                </button>
                <div id="photo-submenu" class="sub-menu">
                  <div class="sub-menu-grid">
                    {photographyNav.map((sub) => (
                      <a href={sub.href} class:list={['sub-link', isActive(sub.href) ? 'text-gold' : '']}>{sub.label}</a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                class:list={['menu-link', isActive(item.href) ? 'text-gold' : '']}
              >
                {item.label}
              </a>
            )}
            <div class="menu-separator"></div>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Bottom CTA + socials -->
    <div class="menu-footer">
      <a href="/contact/" class="menu-cta">
        Book Your Session
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <div class="flex items-center gap-5 mt-5">
        <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29.94 29.94 0 001 12a29.94 29.94 0 00.46 5.58 2.78 2.78 0 001.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 001.94-2A29.94 29.94 0 0023 12a29.94 29.94 0 00-.46-5.58z"/><path d="M9.75 15.02l5.75-3.27-5.75-3.27v6.54z"/></svg>
        </a>
        <a href={`mailto:${site.email}`} aria-label="Email" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
        <span class="text-[0.7rem] font-light text-ink-muted/50 ml-auto">Edmonton, AB</span>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var openBtn = document.getElementById('nav-open');
    var closeBtn = document.getElementById('nav-close');
    var nav = document.getElementById('mobile-nav');
    var header = document.getElementById('mobile-header');
    var photoToggle = document.getElementById('photo-toggle');
    var photoSubmenu = document.getElementById('photo-submenu');

    // Guard against missing elements — prevents crash if DOM structure changes
    if (!openBtn || !closeBtn || !nav || !header) return;

    var savedScrollY = 0;

    function openMenu() {
      savedScrollY = window.scrollY;
      nav.classList.add('is-open');
      openBtn.classList.add('is-open');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.top = '-' + savedScrollY + 'px';
    }

    function closeMenu() {
      nav.classList.remove('is-open');
      openBtn.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
      document.body.style.top = '';
      window.scrollTo(0, savedScrollY);
    }

    openBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    // Close on escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && nav.classList.contains('is-open')) closeMenu();
    });

    // Photography sub-menu toggle
    if (photoToggle) {
      photoToggle.addEventListener('click', function() {
        if (photoSubmenu) photoSubmenu.classList.toggle('is-expanded');
        photoToggle.classList.toggle('is-expanded');
      });
    }

    // Close menu on nav link click
    nav.querySelectorAll('a[href]').forEach(function(link) {
      link.addEventListener('click', function() {
        setTimeout(closeMenu, 150);
      });
    });

    // Scrolled header state — throttled to prevent excessive reflows
    var scrollTicking = false;
    window.addEventListener('scroll', function() {
      if (!scrollTicking) {
        scrollTicking = true;
        requestAnimationFrame(function() {
          if (window.scrollY > 10) {
            header.classList.add('header-scrolled');
          } else {
            header.classList.remove('header-scrolled');
          }
          scrollTicking = false;
        });
      }
    }, { passive: true });
  })();
</script>

<style>
  /* ── Hamburger icon ── */
  .hamburger {
    width: 28px;
    height: 20px;
    position: relative;
    cursor: pointer;
    background: none;
    border: none;
    padding: 10px;
    margin: -10px;
    margin-right: 14px;
    -webkit-tap-highlight-color: transparent;
  }
  .hamburger span {
    display: block;
    position: absolute;
    left: 10px;
    width: 28px;
    height: 1.5px;
    background: #2C2825;
    transition: all 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: center;
    border-radius: 1px;
  }
  .hamburger span:nth-child(1) { top: 10px; }
  .hamburger span:nth-child(2) { top: 19px; }
  .hamburger span:nth-child(3) { top: 28px; }

  /* Hamburger → X animation */
  .hamburger.is-open span:nth-child(1) {
    top: 19px;
    transform: rotate(45deg);
  }
  .hamburger.is-open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.is-open span:nth-child(3) {
    top: 19px;
    transform: rotate(-45deg);
  }

  /* ── Scrolled header ── */
  .header-scrolled {
    background: rgba(250, 248, 245, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.04);
    padding-top: 0.75rem !important;
    padding-bottom: 0.75rem !important;
  }

  /* ── Full-screen overlay ── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 10001;
    background: #FAF8F5;
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-overlay.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  /* Faster close */
  .mobile-overlay:not(.is-open) {
    transition-duration: 0.35s;
  }

  .mobile-overlay-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: max(24px, env(safe-area-inset-top, 24px)) max(28px, env(safe-area-inset-right, 28px)) max(24px, env(safe-area-inset-bottom, 24px)) max(28px, env(safe-area-inset-left, 28px));
  }

  /* ── Close button ── */
  .close-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2C2825;
    padding: 8px 0;
    -webkit-tap-highlight-color: transparent;
  }
  .close-x {
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1;
    margin-top: -1px;
  }

  /* ── Menu items ── */
  .menu-item {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Staggered entrance */
  .mobile-overlay.is-open .menu-item {
    opacity: 1;
    transform: translateY(0);
  }
  .mobile-overlay.is-open .menu-item:nth-child(1) { transition-delay: 0.15s; }
  .mobile-overlay.is-open .menu-item:nth-child(2) { transition-delay: 0.21s; }
  .mobile-overlay.is-open .menu-item:nth-child(3) { transition-delay: 0.27s; }
  .mobile-overlay.is-open .menu-item:nth-child(4) { transition-delay: 0.33s; }
  .mobile-overlay.is-open .menu-item:nth-child(5) { transition-delay: 0.39s; }
  .mobile-overlay.is-open .menu-item:nth-child(6) { transition-delay: 0.45s; }
  .mobile-overlay.is-open .menu-item:nth-child(7) { transition-delay: 0.51s; }
  /* Reset delay on close */
  .mobile-overlay:not(.is-open) .menu-item {
    transition-delay: 0s !important;
  }

  .menu-link {
    display: block;
    font-family: 'Canela', Georgia, serif;
    font-size: clamp(1.75rem, 5vw, 2.25rem);
    font-weight: 300;
    line-height: 1.2;
    color: #2C2825;
    text-decoration: none;
    padding: 10px 0;
    letter-spacing: -0.01em;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.3s ease;
  }
  .menu-link:active,
  .menu-link:hover {
    color: #C9A86C;
  }
  .menu-link.text-gold {
    color: #C9A86C;
  }

  .menu-separator {
    height: 1px;
    background: #E8E3DD;
    width: 100%;
  }

  /* ── Badge ── */
  .menu-badge {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .badge-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    color: #C9A86C;
    letter-spacing: 0.02em;
  }
  .badge-icon {
    color: #C9A86C;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    display: flex;
  }
  .menu-link.is-expanded .badge-icon {
    transform: rotate(45deg);
  }
  .menu-link.is-expanded .badge-text {
    opacity: 0;
  }

  /* ── Photography sub-menu ── */
  .sub-menu {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s ease,
      padding 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    padding: 0;
  }
  .sub-menu.is-expanded {
    max-height: 140px;
    opacity: 1;
    padding: 8px 0 12px 0;
  }
  .sub-menu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 20px;
  }
  .sub-link {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: #6B6560;
    text-decoration: none;
    padding: 8px 0;
    transition: color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .sub-link:active,
  .sub-link:hover {
    color: #C9A86C;
  }
  .sub-link.text-gold {
    color: #C9A86C;
  }

  /* ── Menu footer ── */
  .menu-footer {
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid #E8E3DD;
  }
  .menu-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #C9A86C;
    text-decoration: none;
    padding: 12px 0;
    -webkit-tap-highlight-color: transparent;
  }
  .menu-cta svg {
    transition: transform 0.3s ease;
  }
  .menu-cta:active svg,
  .menu-cta:hover svg {
    transform: translateX(4px);
  }
  .social-icon {
    color: #6B6560;
    transition: color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .social-icon:hover,
  .social-icon:active {
    color: #C9A86C;
  }
</style>
