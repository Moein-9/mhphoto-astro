---
import '../styles/global.css';
import Sidebar from '../components/layout/Sidebar.astro';
import MobileNav from '../components/layout/MobileNav.astro';
import GrainOverlay from '../components/layout/GrainOverlay.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articleMeta?: {
    publishedTime?: string;
    author?: string;
  };
  pageClass?: string;
  noindex?: boolean;
}

const {
  title,
  description = '',
  ogImage = '/og/home.jpg',
  ogType = 'website',
  articleMeta,
  pageClass = '',
  noindex = false,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Hreflang -->
  <link rel="alternate" hreflang="en-CA" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="MH Photography" />
  <meta property="og:locale" content="en_CA" />
  {ogType === 'article' && articleMeta?.publishedTime && (
    <meta property="article:published_time" content={articleMeta.publishedTime} />
  )}
  {ogType === 'article' && articleMeta?.author && (
    <meta property="article:author" content={articleMeta.author} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Google Analytics 4 — Enhanced Tracking -->
  {import.meta.env.PROD && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.ga4}`}></script>
    <script define:vars={{ ga4Id: site.ga4 }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id, {
        page_path: window.location.pathname,
        page_title: document.title,
        send_page_view: true,
      });

      // Track outbound link clicks
      document.addEventListener('click', function(e) {
        const link = e.target.closest('a[href]');
        if (!link) return;
        const url = link.getAttribute('href');
        if (url && url.startsWith('http') && !url.includes('mhphoto.ca')) {
          gtag('event', 'click', {
            event_category: 'outbound',
            event_label: url,
            transport_type: 'beacon',
          });
        }
      });

      // Track scroll depth (25%, 50%, 75%, 100%)
      (function() {
        var marks = [25, 50, 75, 100], fired = {};
        window.addEventListener('scroll', function() {
          var pct = Math.round(100 * (window.scrollY + window.innerHeight) / document.body.scrollHeight);
          marks.forEach(function(m) {
            if (pct >= m && !fired[m]) {
              fired[m] = true;
              gtag('event', 'scroll_depth', { event_category: 'engagement', event_label: m + '%', value: m });
            }
          });
        }, { passive: true });
      })();

      // Track contact form submission
      document.addEventListener('submit', function(e) {
        if (e.target.id === 'contact-form') {
          gtag('event', 'generate_lead', { event_category: 'contact', event_label: 'contact_form' });
        }
      });

      // Track CTA button clicks
      document.addEventListener('click', function(e) {
        var btn = e.target.closest('a[href="/contact/"]');
        if (btn) gtag('event', 'cta_click', { event_category: 'engagement', event_label: btn.textContent.trim() });
      });
    </script>
  )}

  <!-- Preconnect hints for external resources -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://www.youtube-nocookie.com" />
  <link rel="dns-prefetch" href="https://img.youtube.com" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://mhphoto.ca" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;200;300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="MH Photography Blog" href="/blog/rss.xml" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/logo.png" />

  <slot name="head" />
</head>

<body class:list={['antialiased overflow-x-hidden bg-cream', pageClass]}>
  <!-- Skip to content — accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[99999] focus:bg-ink focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:text-sm">
    Skip to main content
  </a>

  <GrainOverlay />
  <MobileNav />

  <div class="max-w-[1390px] w-full mx-auto min-h-screen xl:grid xl:grid-cols-[262px_1fr] xl:gap-12">
    <Sidebar />
    <!-- Spacer for fixed sidebar -->
    <div class="hidden xl:block"></div>

    <div class="pt-[88px] xl:pt-12 pb-12 md:pb-20 px-6 xl:px-8 xl:max-w-[960px] relative">
      <main id="main-content">
        <slot />
      </main>

      <!-- SEO Footer -->
      <footer class="mt-24 pt-10 border-t border-[#e0dcd6]">
        <!-- Sitemap Links -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-10">
          <div>
            <h4 class="text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-ink mb-3">Photography</h4>
            <ul class="space-y-2">
              <li><a href="/photography/weddings/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Wedding Photography</a></li>
              <li><a href="/photography/indian-weddings/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Indian Wedding Photography</a></li>
              <li><a href="/photography/family/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Family Photography</a></li>
              <li><a href="/photography/engagement/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Engagement Photography</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-ink mb-3">Services</h4>
            <ul class="space-y-2">
              <li><a href="/videography/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Wedding Videography</a></li>
              <li><a href="/pricing/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Packages & Pricing</a></li>
              <li><a href="/contact/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Contact / Inquire</a></li>
              <li><a href="/about/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">About Moein</a></li>
              <li><a href="/blog/" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-ink mb-3">Areas We Serve</h4>
            <ul class="space-y-2">
              <li><span class="text-[0.75rem] font-light text-ink-soft">Edmonton, AB</span></li>
              <li><span class="text-[0.75rem] font-light text-ink-soft">Sherwood Park</span></li>
              <li><span class="text-[0.75rem] font-light text-ink-soft">St. Albert</span></li>
              <li><span class="text-[0.75rem] font-light text-ink-soft">Spruce Grove</span></li>
            </ul>
          </div>
          <div>
            <h4 class="text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-ink mb-3">Connect</h4>
            <ul class="space-y-2">
              <li><a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Instagram</a></li>
              <li><a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">YouTube</a></li>
              <li><a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">Facebook</a></li>
              <li><a href={`mailto:${site.email}`} class="text-[0.75rem] font-light text-ink-soft hover:text-gold transition-colors">{site.email}</a></li>
            </ul>
          </div>
        </div>

        <!-- Keyword-rich paragraph -->
        <p class="text-[0.7rem] font-light text-ink-muted/60 leading-relaxed mb-6 max-w-[700px]">
          MH Photography is the best wedding photographer in Edmonton, offering both wedding photography and wedding videographer Edmonton services. We specialize in affordable wedding photography, Indian wedding photography, family portraits, and engagement sessions. Wedding photographer cost starts at $2,250 for photography and $3,750 for videography. We also cover elopement photography and offer wedding photography locations across Edmonton, Sherwood Park, St. Albert, Spruce Grove, and all of Alberta. {site.booking}.
        </p>

        <!-- Bottom bar -->
        <div class="flex justify-between items-center pt-6 border-t border-[#e0dcd6]">
          <p class="text-[0.6rem] tracking-[0.08em] uppercase text-ink-muted/50 font-light">
            &copy; {new Date().getFullYear()} {site.name} &middot; Edmonton, Alberta
          </p>
          <div class="flex gap-3 text-ink-muted/50">
            <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-gold transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.908 4.908 0 0 1 1.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.883 4.883 0 0 1-1.153 1.772 4.915 4.915 0 0 1-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.89 4.89 0 0 1-1.772-1.153 4.904 4.904 0 0 1-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.88 4.88 0 0 1 1.153-1.772A4.897 4.897 0 0 1 5.45 2.525c.638-.248 1.362-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.333a3.333 3.333 0 1 1 0-6.666 3.333 3.333 0 0 1 0 6.666zm5.338-9.87a1.2 1.2 0 1 0 0 2.4 1.2 1.2 0 0 0 0-2.4z"/></svg>
            </a>
            <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="hover:text-gold transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M21.543 6.498C22 8.28 22 12 22 12s0 3.72-.457 5.502c-.254.985-.997 1.76-1.938 2.022C17.896 20 12 20 12 20s-5.893 0-7.605-.476c-.945-.266-1.687-1.04-1.938-2.022C2 15.72 2 12 2 12s0-3.72.457-5.502c.254-.985.997-1.76 1.938-2.022C6.107 4 12 4 12 4s5.896 0 7.605.476c.945.266 1.687 1.04 1.938 2.022zM10 15.5l6-3.5-6-3.5v7z"/></svg>
            </a>
            <a href={`mailto:${site.email}`} aria-label="Email" class="hover:text-gold transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h18a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm9.06 8.683L5.648 6.238 4.353 7.762l7.72 6.555 7.581-6.56-1.308-1.513-6.286 5.439z"/></svg>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </div>

  <!-- Scroll reveal observer -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
